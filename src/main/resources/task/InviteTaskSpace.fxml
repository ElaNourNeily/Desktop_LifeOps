<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="root"
            maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="780.0" prefWidth="1100.0"
            styleClass="root-pane"
            stylesheets="@stylespace.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controller.task.InviteTaskSpace">
    <children>

        <VBox prefHeight="780.0" prefWidth="229.0" styleClass="sidebar"
              AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>

                <HBox alignment="CENTER_LEFT" prefHeight="70.0" prefWidth="229.0" spacing="10.0">
                    <padding><Insets left="20.0" /></padding>
                    <children>
                        <ImageView fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true">
                            <image><Image url="@../../../assets/5555.png" /></image>
                        </ImageView>
                        <Label styleClass="logo-label" text="LifeOps">
                            <font><Font name="System Bold" size="18.0" /></font>
                        </Label>
                    </children>
                </HBox>

                <VBox prefWidth="229.0" spacing="5.0">
                    <padding><Insets top="20.0" /></padding>
                    <children>

                        <HBox alignment="CENTER_LEFT" prefHeight="40.0" prefWidth="229.0" spacing="10.0" styleClass="nav-item">
                            <padding><Insets left="20.0" /></padding>
                            <children>
                                <ImageView fitHeight="24.0" fitWidth="24.0" pickOnBounds="true" preserveRatio="true">
                                    <image><Image url="@../../../assets/home_24dp_A1A1AA%20_FILL0_wght400_GRAD0_opsz24.png" /></image>
                                </ImageView>
                                <Label styleClass="nav-label" text="Tableau de bord"><font><Font size="14.0" /></font></Label>
                            </children>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" prefHeight="40.0" prefWidth="229.0" spacing="10.0" styleClass="nav-item-active">
                            <padding><Insets left="20.0" /></padding>
                            <children>
                                <ImageView fitHeight="24.0" fitWidth="24.0" pickOnBounds="true" preserveRatio="true">
                                    <image><Image url="@../../../assets/done_all_24dp_7A4ED4_FILL0_wght400_GRAD0_opsz24.png" /></image>
                                </ImageView>
                                <Label styleClass="nav-label-active" text="Tâches"><font><Font size="14.0" /></font></Label>
                            </children>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" prefHeight="40.0" prefWidth="229.0" spacing="10.0" styleClass="nav-item">
                            <padding><Insets left="20.0" /></padding>
                            <children>
                                <ImageView fitHeight="24.0" fitWidth="24.0" pickOnBounds="true" preserveRatio="true">
                                    <image><Image url="@../../../assets/account_balance_wallet_24dp_A1A1AA%20_FILL0_wght400_GRAD0_opsz24.png" /></image>
                                </ImageView>
                                <Label styleClass="nav-label" text="Finance"><font><Font size="14.0" /></font></Label>
                            </children>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" prefHeight="40.0" prefWidth="229.0" spacing="10.0" styleClass="nav-item">
                            <padding><Insets left="20.0" /></padding>
                            <children>
                                <ImageView fitHeight="24.0" fitWidth="24.0" pickOnBounds="true" preserveRatio="true">
                                    <image><Image url="@../../../assets/target_24dp_A1A1AA%20_FILL0_wght400_GRAD0_opsz24.png" /></image>
                                </ImageView>
                                <Label styleClass="nav-label" text="Objectifs"><font><Font size="14.0" /></font></Label>
                            </children>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" prefHeight="40.0" prefWidth="229.0" spacing="10.0" styleClass="nav-item">
                            <padding><Insets left="20.0" /></padding>
                            <children>
                                <ImageView fitHeight="24.0" fitWidth="24.0" pickOnBounds="true" preserveRatio="true">
                                    <image><Image url="@../../../assets/ecg_heart_24dp_A1A1AA%20_FILL0_wght400_GRAD0_opsz24.png" /></image>
                                </ImageView>
                                <Label styleClass="nav-label" text="Santé"><font><Font size="14.0" /></font></Label>
                            </children>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" prefHeight="40.0" prefWidth="229.0" spacing="10.0" styleClass="nav-item">
                            <padding><Insets left="20.0" /></padding>
                            <children>
                                <ImageView fitHeight="24.0" fitWidth="24.0" pickOnBounds="true" preserveRatio="true">
                                    <image><Image url="@../../../assets/schedule_24dp_A1A1AA%20_FILL0_wght400_GRAD0_opsz24.png" /></image>
                                </ImageView>
                                <Label styleClass="nav-label" text="Temps"><font><Font size="14.0" /></font></Label>
                            </children>
                        </HBox>

                    </children>
                </VBox>

                <VBox VBox.vgrow="ALWAYS" />

                <HBox alignment="CENTER_LEFT" prefHeight="60.0" prefWidth="229.0" spacing="10.0" styleClass="account-box">
                    <padding><Insets bottom="10.0" left="15.0" right="15.0" top="10.0" /></padding>
                    <VBox.margin><Insets bottom="20.0" left="10.0" right="10.0" /></VBox.margin>
                    <children>
                        <ImageView fitHeight="32.0" fitWidth="32.0" pickOnBounds="true" preserveRatio="true">
                            <image><Image url="@../../../assets/account_circle_24dp_A1A1AA%20_FILL0_wght400_GRAD0_opsz24.png" /></image>
                        </ImageView>
                        <Label styleClass="account-label" text="compte"><font><Font size="14.0" /></font></Label>
                    </children>
                </HBox>

            </children>
        </VBox>

        <Line endX="0.0" endY="780.0" startX="0.0" startY="0.0"
              styleClass="sidebar-divider"
              AnchorPane.leftAnchor="229.0" AnchorPane.topAnchor="0.0" />

        <VBox styleClass="main-content"
              AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="229.0"
              AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>

                <HBox alignment="CENTER_LEFT" prefHeight="80.0" spacing="15.0">
                    <padding><Insets left="35.0" right="35.0" top="25.0" bottom="10.0" /></padding>
                    <children>

                        <Button mnemonicParsing="false"
                                onAction="#retourVersKanban"
                                prefHeight="36.0" prefWidth="36.0"
                                styleClass="back-button">
                            <graphic>
                                <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                                    <image><Image url="@../../../assets/arrow_back_ios_24dp_A1A1AA%20_FILL0_wght400_GRAD0_opsz24.png" /></image>
                                </ImageView>
                            </graphic>
                        </Button>

                        <HBox alignment="CENTER_LEFT" spacing="6.0">
                            <children>
                                <Label styleClass="breadcrumb-label" text="Projets" style="-fx-text-fill: #6b6b75; -fx-font-size: 13px;" />
                                <Label text="/" style="-fx-text-fill: #6b6b75; -fx-font-size: 13px;" />
                                <Label fx:id="lblBreadcrumbProject" styleClass="breadcrumb-label" text="" style="-fx-text-fill: #6b6b75; -fx-font-size: 13px;" />
                                <Label text="/" style="-fx-text-fill: #6b6b75; -fx-font-size: 13px;" />
                                <Label text="Inviter" style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;" />
                            </children>
                        </HBox>

                    </children>
                </HBox>

                <ScrollPane styleClass="scroll-area" fitToWidth="true" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox spacing="30.0">
                            <padding><Insets bottom="40.0" left="35.0" right="35.0" top="10.0" /></padding>
                            <children>

                                <VBox spacing="8.0">
                                    <children>
                                        <Label styleClass="page-title" text="Inviter des membres">
                                            <font><Font name="System Bold" size="28.0" /></font>
                                        </Label>
                                        <Label styleClass="page-subtitle" text="Recherchez un utilisateur par email ou nom pour l'ajouter au projet.">
                                            <font><Font size="13.0" /></font>
                                        </Label>
                                    </children>
                                </VBox>

                                <VBox spacing="0.0">
                                    <children>

                                        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="invite-search-box"
                                              style="-fx-background-color: #0B0C10; -fx-background-radius: 12; -fx-border-color: #39393B; -fx-border-radius: 12; -fx-padding: 0 16 0 16; -fx-pref-height: 52;">
                                            <children>
                                                <ImageView fitHeight="18.0" fitWidth="18.0" pickOnBounds="true" preserveRatio="true">
                                                    <image><Image url="@../../../assets/search_24dp_A1A1AA_FILL0_wght400_GRAD0_opsz24.png" /></image>
                                                </ImageView>
                                                <TextField fx:id="searchField"
                                                           promptText="Taper un nom ou email..."
                                                           styleClass="invite-search-field"
                                                           maxWidth="1.7976931348623157E308"
                                                           HBox.hgrow="ALWAYS"
                                                           style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: #6b6b75; -fx-font-size: 14px;" />
                                            </children>
                                        </HBox>

                                        <VBox fx:id="searchResultsContainer" spacing="0.0" managed="false" visible="false"
                                              style="-fx-background-color: #17191F; -fx-border-color: #39393B; -fx-border-radius: 0 0 12 12; -fx-background-radius: 0 0 12 12; -fx-border-width: 0 1 1 1;">
                                            <children>
                                                <Label fx:id="lblNoResults" text="Aucun utilisateur trouvé."
                                                       styleClass="empty-state-label"
                                                       managed="false" visible="false">
                                                    <padding><Insets top="14.0" bottom="14.0" left="20.0" right="20.0" /></padding>
                                                </Label>
                                            </children>
                                        </VBox>

                                    </children>
                                </VBox>

                                <HBox alignment="CENTER">
                                    <children>
                                        <Hyperlink fx:id="lienVoirEquipe"
                                                   text="Voir les membres actuels de l'équipe →"
                                                   onAction="#naviguerVersEquipe"
                                                   style="-fx-text-fill: #8b5cf6; -fx-font-size: 14px; -fx-border-color: transparent; -fx-cursor: hand;" />
                                    </children>
                                </HBox>

                                <VBox fx:id="equipeSection" spacing="15.0" managed="false" visible="false">
                                    <children>

                                        <Line endX="800.0" startX="0.0" styleClass="section-divider" />

                                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                                            <children>
                                                <Label text="👥" style="-fx-font-size: 16px;" />
                                                <Label styleClass="section-title" text="Membres de l'équipe">
                                                    <font><Font name="System Bold" size="16.0" /></font>
                                                </Label>
                                            </children>
                                        </HBox>

                                        <VBox fx:id="membresContainer" spacing="10.0" />

                                        <Label fx:id="lblAucunMembre"
                                               styleClass="empty-state-label"
                                               text="Aucun membre pour l'instant. Invitez quelqu'un ci-dessus."
                                               managed="false" visible="false" />

                                    </children>
                                </VBox>

                            </children>
                        </VBox>
                    </content>
                </ScrollPane>

            </children>
        </VBox>

    </children>
</AnchorPane>