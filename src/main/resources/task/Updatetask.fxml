<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.Font?>

<!--
    UPDATETASK.FXML — Modifier une tâche
    Dark Mode default via styleRead.css
    Light Mode: root.getStyleClass().add("light-mode");
-->

<AnchorPane fx:id="root" maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="780.0" prefWidth="1400.0"
            styleClass="root-pane"
            stylesheets="@styleRead.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controller.task.UpdateTask">
   <children>

      <!-- ═══════════════════════════════════════
           SIDEBAR
      ════════════════════════════════════════ -->
      <VBox prefHeight="780.0" prefWidth="229.0" styleClass="sidebar"
            AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>

            <!-- Logo -->
            <HBox alignment="CENTER_LEFT" prefHeight="70.0" prefWidth="229.0" spacing="10.0">
               <padding><Insets left="20.0" /></padding>
               <children>
                  <ImageView fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true">
                     <image><Image url="@../../../assets/5555.png" /></image>
                  </ImageView>
                  <Label styleClass="logo-label" text="LifeOps">
                     <font><Font name="System Bold" size="18.0" /></font>
                  </Label>
               </children>
            </HBox>

            <!-- Navigation Menu -->
            <VBox prefHeight="300.0" prefWidth="229.0" spacing="5.0">
               <padding><Insets top="20.0" /></padding>
               <children>

                  <HBox alignment="CENTER_LEFT" prefHeight="40.0" prefWidth="229.0" spacing="10.0" styleClass="nav-item">
                     <padding><Insets left="20.0" /></padding>
                     <children>
                        <ImageView fitHeight="24.0" fitWidth="24.0" pickOnBounds="true" preserveRatio="true">
                           <image><Image url="@../../../assets/home_24dp_A1A1AA%20_FILL0_wght400_GRAD0_opsz24.png" /></image>
                        </ImageView>
                        <Label styleClass="nav-label" text="Tableau de bord"><font><Font size="14.0" /></font></Label>
                     </children>
                  </HBox>

                  <!-- Tasks — Active -->
                  <HBox alignment="CENTER_LEFT" prefHeight="40.0" prefWidth="229.0" spacing="10.0" styleClass="nav-item-active">
                     <padding><Insets left="20.0" /></padding>
                     <children>
                        <ImageView fitHeight="24.0" fitWidth="24.0" pickOnBounds="true" preserveRatio="true">
                           <image><Image url="@../../../assets/done_all_24dp_7A4ED4_FILL0_wght400_GRAD0_opsz24.png" /></image>
                        </ImageView>
                        <Label styleClass="nav-label-active" text="Tâches"><font><Font size="14.0" /></font></Label>
                     </children>
                  </HBox>

                  <HBox alignment="CENTER_LEFT" prefHeight="40.0" prefWidth="229.0" spacing="10.0" styleClass="nav-item">
                     <padding><Insets left="20.0" /></padding>
                     <children>
                        <ImageView fitHeight="24.0" fitWidth="24.0" pickOnBounds="true" preserveRatio="true">
                           <image><Image url="@../../../assets/account_balance_wallet_24dp_A1A1AA%20_FILL0_wght400_GRAD0_opsz24.png" /></image>
                        </ImageView>
                        <Label styleClass="nav-label" text="Finance"><font><Font size="14.0" /></font></Label>
                     </children>
                  </HBox>

                  <HBox alignment="CENTER_LEFT" prefHeight="40.0" prefWidth="229.0" spacing="10.0" styleClass="nav-item">
                     <padding><Insets left="20.0" /></padding>
                     <children>
                        <ImageView fitHeight="24.0" fitWidth="24.0" pickOnBounds="true" preserveRatio="true">
                           <image><Image url="@../../../assets/target_24dp_A1A1AA%20_FILL0_wght400_GRAD0_opsz24.png" /></image>
                        </ImageView>
                        <Label styleClass="nav-label" text="Objectifs"><font><Font size="14.0" /></font></Label>
                     </children>
                  </HBox>

                  <HBox alignment="CENTER_LEFT" prefHeight="40.0" prefWidth="229.0" spacing="10.0" styleClass="nav-item">
                     <padding><Insets left="20.0" /></padding>
                     <children>
                        <ImageView fitHeight="24.0" fitWidth="24.0" pickOnBounds="true" preserveRatio="true">
                           <image><Image url="@../../../assets/ecg_heart_24dp_A1A1AA%20_FILL0_wght400_GRAD0_opsz24.png" /></image>
                        </ImageView>
                        <Label styleClass="nav-label" text="Santé"><font><Font size="14.0" /></font></Label>
                     </children>
                  </HBox>

                  <HBox alignment="CENTER_LEFT" prefHeight="40.0" prefWidth="229.0" spacing="10.0" styleClass="nav-item">
                     <padding><Insets left="20.0" /></padding>
                     <children>
                        <ImageView fitHeight="24.0" fitWidth="24.0" pickOnBounds="true" preserveRatio="true">
                           <image><Image url="@../../../assets/schedule_24dp_A1A1AA%20_FILL0_wght400_GRAD0_opsz24.png" /></image>
                        </ImageView>
                        <Label styleClass="nav-label" text="Temps"><font><Font size="14.0" /></font></Label>
                     </children>
                  </HBox>

               </children>
            </VBox>

            <VBox VBox.vgrow="ALWAYS" />

            <!-- Account -->
            <HBox alignment="CENTER_LEFT" prefHeight="60.0" prefWidth="229.0"
                  spacing="10.0" styleClass="account-box">
               <padding><Insets bottom="10.0" left="15.0" right="15.0" top="10.0" /></padding>
               <VBox.margin><Insets bottom="20.0" left="10.0" right="10.0" /></VBox.margin>
               <children>
                  <ImageView fitHeight="32.0" fitWidth="32.0" pickOnBounds="true" preserveRatio="true">
                     <image><Image url="@../../../assets/account_circle_24dp_A1A1AA%20_FILL0_wght400_GRAD0_opsz24.png" /></image>
                  </ImageView>
                  <Label styleClass="account-label" text="compte"><font><Font size="14.0" /></font></Label>
               </children>
            </HBox>

         </children>
      </VBox>

      <!-- Sidebar separator -->
      <Line endX="0.0" endY="780.0" startX="0.0" startY="0.0"
            styleClass="sidebar-divider"
            AnchorPane.leftAnchor="229.0" AnchorPane.topAnchor="0.0" />

      <!-- ═══════════════════════════════════════
           MAIN CONTENT
      ════════════════════════════════════════ -->
      <VBox styleClass="main-content"
            AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="229.0"
            AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>

            <!-- ── Header ── -->
            <HBox alignment="CENTER_LEFT" prefHeight="80.0" spacing="15.0">
               <padding><Insets left="50.0" right="50.0" top="30.0" /></padding>
               <children>

                  <!-- Title block -->
                  <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Label styleClass="page-title" text="Modifier Tâche">
                           <font><Font name="System Bold" size="24.0" /></font>
                        </Label>
                        <Label styleClass="page-subtitle" text="Modifier les détails de la tâche">
                           <font><Font size="13.0" /></font>
                        </Label>
                     </children>
                  </VBox>

                  <!-- Delete button (top right) -->
                  <Button fx:id="btnSupprimer" mnemonicParsing="false"
                          onAction="#supprimerTache"
                          styleClass="delete-button"
                          text="🗑  Supprimer">
                     <font><Font name="System Bold" size="13.0" /></font>
                  </Button>

               </children>
            </HBox>

            <!-- Separator -->
            <Line styleClass="section-divider">
               <VBox.margin><Insets left="50.0" right="50.0" /></VBox.margin>
            </Line>

            <!-- ── Form (scrollable center) ── -->
            <VBox alignment="TOP_CENTER" VBox.vgrow="ALWAYS">
               <padding><Insets bottom="40.0" left="50.0" right="50.0" top="30.0" /></padding>
               <children>

                  <!-- Form Card -->
                  <VBox maxWidth="700.0" prefWidth="700.0" spacing="20.0" styleClass="form-card">
                     <padding><Insets bottom="35.0" left="35.0" right="35.0" top="35.0" /></padding>
                     <children>

                        <!-- Titre -->
                        <VBox spacing="8.0">
                           <children>
                              <Label styleClass="field-label" text="Titre de la tâche">
                                 <font><Font size="13.0" /></font>
                              </Label>
                              <TextField fx:id="titre" promptText="Entrez le titre..."
                                         styleClass="form-field" />
                           </children>
                        </VBox>

                        <!-- Priorité + Difficulté -->
                        <HBox spacing="20.0">
                           <children>
                              <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label styleClass="field-label" text="Priorité">
                                       <font><Font size="13.0" /></font>
                                    </Label>
                                    <ChoiceBox fx:id="priorite" maxWidth="1.7976931348623157E308"
                                               styleClass="form-choice" />
                                 </children>
                              </VBox>
                              <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label styleClass="field-label" text="Difficulté (1 à 5)">
                                       <font><Font size="13.0" /></font>
                                    </Label>
                                    <ChoiceBox fx:id="difficulte" maxWidth="1.7976931348623157E308"
                                               styleClass="form-choice" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>

                        <!-- Statut + Projet -->
                        <HBox spacing="20.0">
                           <children>
                              <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label styleClass="field-label" text="Statut de la tâche">
                                       <font><Font size="13.0" /></font>
                                    </Label>
                                    <ChoiceBox fx:id="statut" maxWidth="1.7976931348623157E308"
                                               styleClass="form-choice" />
                                 </children>
                              </VBox>
                              <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label styleClass="field-label" text="Projet associé (Optionnel)">
                                       <font><Font size="13.0" /></font>
                                    </Label>
                                    <ChoiceBox fx:id="taskSpace" maxWidth="1.7976931348623157E308"
                                               styleClass="form-choice" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>

                        <!-- Date limite -->
                        <VBox spacing="8.0">
                           <children>
                              <Label styleClass="field-label" text="Date limite d'échéance">
                                 <font><Font size="13.0" /></font>
                              </Label>
                              <DatePicker fx:id="deadline" maxWidth="1.7976931348623157E308"
                                          prefHeight="38.0" styleClass="form-datepicker" />
                           </children>
                        </VBox>

                        <!-- Description -->
                        <VBox spacing="8.0">
                           <children>
                              <Label styleClass="field-label" text="Description détaillée">
                                 <font><Font size="13.0" /></font>
                              </Label>
                              <TextArea fx:id="description" prefHeight="120.0"
                                        promptText="Description de la tâche..."
                                        styleClass="form-field" wrapText="true" />
                           </children>
                        </VBox>

                        <!-- Footer buttons -->
                        <HBox alignment="CENTER_RIGHT" spacing="12.0">
                           <VBox.margin><Insets top="10.0" /></VBox.margin>
                           <children>
                              <!-- Annuler → back to ReadTask -->
                              <Button fx:id="btnAnnuler" mnemonicParsing="false"
                                      onAction="#annuler"
                                      styleClass="cancel-button"
                                      text="Annuler" prefHeight="42.0" prefWidth="130.0">
                                 <font><Font size="13.0" /></font>
                              </Button>
                              <!-- Mettre à jour -->
                              <Button fx:id="btnUpdate" mnemonicParsing="false"
                                      onAction="#mettreAJour"
                                      styleClass="submit-button"
                                      text="Mettre à jour" prefHeight="42.0" prefWidth="160.0">
                                 <font><Font name="System Bold" size="13.0" /></font>
                              </Button>
                           </children>
                        </HBox>

                     </children>
                  </VBox>

               </children>
            </VBox>

         </children>
      </VBox>

   </children>
</AnchorPane>
