<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="950.0" prefWidth="1250.0" styleClass="main-container" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.DashboardController">
   <children>
      <HBox layoutX="216.0" layoutY="148.0" prefHeight="700.0" prefWidth="1000.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <VBox prefHeight="700.0" prefWidth="250.0" styleClass="sidebar">
               <children>
                  <Label text="LifeOps" textFill="#8b5cf6">
                     <font>
                        <Font name="System Bold" size="24.0" />
                     </font>
                     <VBox.margin>
                        <Insets bottom="50.0" left="20.0" top="10.0" />
                     </VBox.margin>
                  </Label>
                  
                  <VBox spacing="8.0" VBox.vgrow="ALWAYS">
                     <children>
                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleHome" styleClass="nav-button" text="🏠  Tableau de bord" />
                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleActivities" styleClass="nav-button" text="✅  Activités" />
                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handlePlannings" styleClass="nav-button" text="📅  Plannings" />
                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="nav-button" text="🎯  Objectifs" />
                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="nav-button" text="🏷  Budget" />
                     </children>
                  </VBox>
                  
                  <VBox styleClass="sidebar-profile">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                           <children>
                              <Label style="-fx-background-color: #8b5cf6; -fx-background-radius: 50; -fx-min-width: 32; -fx-min-height: 32; -fx-alignment: center; -fx-text-fill: white;" text="👤" />
                              <VBox>
                                 <children>
                                    <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13;" text="Mon Compte" />
                                    <Label style="-fx-text-fill: #71717a; -fx-font-size: 11;" text="Utilisateur #5" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </VBox>
            <!-- Zone de contenu dynamique -->
            <AnchorPane fx:id="contentArea" prefHeight="200.0" prefWidth="100.0" styleClass="content-area" HBox.hgrow="ALWAYS">
               <children>
                  <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                     <children>
                        <Label styleClass="header-title" text="Aperçu du Dashboard">
                           <font>
                              <Font name="System Bold" size="30.0" />
                           </font>
                           <VBox.margin>
                              <Insets bottom="30.0" left="30.0" top="30.0" />
                           </VBox.margin>
                        </Label>
                        <HBox prefHeight="150.0" prefWidth="750.0" spacing="30.0">
                           <children>
                              <VBox prefHeight="150.0" prefWidth="220.0" styleClass="stat-card">
                                 <children>
                                    <Label text="Activités Totales" textFill="#7c7c7c">
                                       <font>
                                          <Font size="14.0" />
                                       </font>
                                    </Label>
                                    <Label fx:id="totalActivitiesLabel" text="0">
                                       <font>
                                          <Font name="System Bold" size="36.0" />
                                       </font>
                                    </Label>
                                 </children>
                                 <padding>
                                    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                                 </padding>
                              </VBox>
                              <VBox prefHeight="150.0" prefWidth="220.0" styleClass="stat-card">
                                 <children>
                                    <Label text="Plannings" textFill="#7c7c7c">
                                       <font>
                                          <Font size="14.0" />
                                       </font>
                                    </Label>
                                    <Label fx:id="totalPlanningsLabel" text="0">
                                       <font>
                                          <Font name="System Bold" size="36.0" />
                                       </font>
                                    </Label>
                                 </children>
                                 <padding>
                                    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                                 </padding>
                              </VBox>
                           </children>
                           <VBox.margin>
                              <Insets left="30.0" />
                           </VBox.margin>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </AnchorPane>
         </children>
      </HBox>
   </children>
</AnchorPane>
