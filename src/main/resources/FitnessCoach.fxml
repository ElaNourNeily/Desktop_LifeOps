<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="900.0" style="-fx-background-color: #0f172a;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.FitnessCoachController">
   <children>
      <VBox spacing="25.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>
         <children>
            <HBox alignment="CENTER_LEFT" spacing="15.0">
               <children>
                  <Button onAction="#goBack" style="-fx-background-color: #1e293b; -fx-text-fill: white;" text="&lt; Retour" />
                  <Label text="Coach Fitness Personnel" textFill="#38bdf8">
                     <font><Font name="System Bold" size="28.0" /></font>
                  </Label>
               </children>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #1e293b; -fx-padding: 20; -fx-background-radius: 15;">
               <children>
                  <VBox spacing="5.0">
                     <children>
                        <Label text="Quel muscle voulez-vous travailler ?" textFill="#94a3b8" />
                        <ComboBox fx:id="comboMuscles" prefHeight="40.0" prefWidth="250.0" promptText="Choisir un muscle..." style="-fx-background-color: #0f172a; -fx-text-fill: white;" />
                     </children>
                  </VBox>
                  <Button fx:id="btnGetPlan" mnemonicParsing="false" onAction="#generateWorkout" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #38bdf8; -fx-text-fill: #0f172a; -fx-font-weight: bold;" text="Obtenir des exercices" translateY="8.0" />
               </children>
            </HBox>

            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
               <content>
                  <VBox fx:id="exerciseContainer" spacing="15.0" />
               </content>
            </ScrollPane>
         </children>
      </VBox>
   </children>
</AnchorPane>
