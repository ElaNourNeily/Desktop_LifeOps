<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<AnchorPane prefWidth="650.0" style="-fx-background-color: transparent;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.Time.ActiviteFormController">
   <children>
      <VBox spacing="20.0" styleClass="card-dark" style="-fx-padding: 30; -fx-background-color: #0f0f12;" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
         <children>
            <!-- HEADER -->
            <HBox alignment="CENTER_LEFT" spacing="20.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleCancel" styleClass="back-button-circle" text="‹" style="-fx-font-size: 24; -fx-text-fill: white;" />
                  <VBox>
                     <children>
                        <Label fx:id="lblFormTitle" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 32;" text="Ajouter une Activité" />
                        <Label fx:id="lblDateSubtitle" style="-fx-text-fill: #71717a;" text="Pour le 19/04/2026" />
                     </children>
                  </VBox>
               </children>
            </HBox>

            <!-- SCROLLABLE CONTENT -->
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
               <content>
                  <VBox spacing="25.0" style="-fx-background-color: rgba(255,255,255,0.02); -fx-background-radius: 20; -fx-padding: 25; -fx-border-color: rgba(255,255,255,0.05); -fx-border-radius: 20;">
                     <children>
                        <!-- Title -->
                        <VBox spacing="8.0">
                           <children>
                              <Label styleClass="indicator-label" text="TITRE DE L'ACTIVITÉ" />
                              <TextField fx:id="txtTitre" promptText="Réunion, Sport, Lecture..." styleClass="form-field" />
                           </children>
                        </VBox>

                        <!-- Times -->
                        <HBox spacing="20.0">
                           <children>
                              <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label styleClass="indicator-label" text="HEURE DE DÉBUT" />
                                    <TextField fx:id="txtHeureDebut" promptText="08:00" styleClass="form-field" />
                                 </children>
                              </VBox>
                              <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label styleClass="indicator-label" text="HEURE DE FIN" />
                                    <TextField fx:id="txtHeureFin" promptText="09:00" styleClass="form-field" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>

                        <!-- Category -->
                        <VBox spacing="8.0">
                           <children>
                              <Label styleClass="indicator-label" text="CATÉGORIE" />
                              <ComboBox fx:id="comboCategorie" maxWidth="Infinity" styleClass="form-choice" promptText="Sélectionner une catégorie" />
                              <Label fx:id="lblWeatherWarning" style="-fx-text-fill: #f59e0b; -fx-font-size: 11; -fx-font-weight: bold;" wrapText="true" />
                           </children>
                        </VBox>

                        <!-- Color Selection -->
                        <VBox spacing="12.0">
                           <children>
                              <Label styleClass="indicator-label" text="COULEUR" />
                              <HBox spacing="15.0" alignment="CENTER_LEFT">
                                 <children>
                                    <HBox fx:id="boxColorEmeraude" spacing="8.0" alignment="CENTER_LEFT" onMouseClicked="#selectEmeraude" style="-fx-cursor: hand;">
                                       <children><Circle radius="12.0" fill="#10b981" /><Label text="Emeraude" style="-fx-text-fill: #71717a; -fx-font-size: 11;" /></children>
                                    </HBox>
                                    <HBox fx:id="boxColorBleu" spacing="8.0" alignment="CENTER_LEFT" onMouseClicked="#selectBleu" style="-fx-cursor: hand;">
                                       <children><Circle radius="12.0" fill="#3b82f6" /><Label text="Bleu" style="-fx-text-fill: #71717a; -fx-font-size: 11;" /></children>
                                    </HBox>
                                    <HBox fx:id="boxColorOrange" spacing="8.0" alignment="CENTER_LEFT" onMouseClicked="#selectOrange" style="-fx-cursor: hand;">
                                       <children><Circle radius="12.0" fill="#f59e0b" /><Label text="Orange" style="-fx-text-fill: #71717a; -fx-font-size: 11;" /></children>
                                    </HBox>
                                    <HBox fx:id="boxColorRose" spacing="8.0" alignment="CENTER_LEFT" onMouseClicked="#selectRose" style="-fx-cursor: hand;">
                                       <children><Circle radius="12.0" fill="#ec4899" /><Label text="Rose" style="-fx-text-fill: #71717a; -fx-font-size: 11;" /></children>
                                    </HBox>
                                    <HBox fx:id="boxColorViolet" spacing="8.0" alignment="CENTER_LEFT" onMouseClicked="#selectViolet" style="-fx-cursor: hand;">
                                       <children><Circle radius="12.0" fill="#8b5cf6" /><Label text="Violet" style="-fx-text-fill: #71717a; -fx-font-size: 11;" /></children>
                                    </HBox>
                                 </children>
                              </HBox>
                           </children>
                        </VBox>

                        <!-- Priority & Urgency & Reminder -->
                        <HBox spacing="20.0">
                           <children>
                              <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label styleClass="indicator-label" text="PRIORITÉ" />
                                    <ComboBox fx:id="comboPriorite" maxWidth="Infinity" styleClass="form-choice" />
                                 </children>
                              </VBox>
                              <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label styleClass="indicator-label" text="NIVEAU D'URGENCE" />
                                    <ComboBox fx:id="comboUrgence" maxWidth="Infinity" styleClass="form-choice" />
                                 </children>
                              </VBox>
                              <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label styleClass="indicator-label" text="RAPPEL" />
                                    <ComboBox fx:id="comboRappel" maxWidth="Infinity" styleClass="form-choice" promptText="Aucun" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>

                        <!-- RECURRENCE SECTION -->
                        <VBox spacing="15.0" style="-fx-background-color: rgba(139,92,246,0.05); -fx-padding: 20; -fx-background-radius: 15; -fx-border-color: rgba(139,92,246,0.1); -fx-border-radius: 15;">
                           <children>
                              <javafx.scene.control.CheckBox fx:id="chkRecurrent" onAction="#handleRecurrenceToggle" text="Activité Récurrente" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13;" />
                              <HBox fx:id="boxRecurrenceSettings" spacing="15.0" visible="false" managed="false">
                                 <children>
                                    <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                       <children>
                                          <Label styleClass="indicator-label" text="FRÉQUENCE" />
                                          <ComboBox fx:id="comboRecurrenceType" maxWidth="Infinity" styleClass="form-choice" promptText="Chaque..." />
                                       </children>
                                    </VBox>
                                    <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                       <children>
                                          <Label styleClass="indicator-label" text="INTERVALLE" />
                                          <TextField fx:id="txtRecurrenceInterval" promptText="1" text="1" styleClass="form-field" />
                                       </children>
                                    </VBox>
                                    <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                       <children>
                                          <Label styleClass="indicator-label" text="JOURS (ex: LUN,MAR)" />
                                          <TextField fx:id="txtRecurrenceDays" promptText="LUN,MER,VEN" styleClass="form-field" />
                                       </children>
                                    </VBox>
                                 </children>
                              </HBox>
                           </children>
                        </VBox>

                        <!-- NEWS SECTION -->
                        <VBox spacing="10.0">
                           <children>
                              <Label styleClass="indicator-label" text="ACTUALITÉS LIÉES" />
                              <VBox fx:id="vboxNews" spacing="8.0" />
                           </children>
                        </VBox>
                     </children>
                  </VBox>
               </content>
            </ScrollPane>

            <!-- FOOTER -->
            <HBox alignment="CENTER_RIGHT" spacing="20.0">
               <children>
                  <Button fx:id="btnDelete" managed="false" mnemonicParsing="false" onAction="#handleDelete" styleClass="btn-delete-ghost" text="🗑 Supprimer l'activité" visible="false" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" onAction="#handleCancel" styleClass="btn-ghost" text="Annuler" />
                  <Button mnemonicParsing="false" onAction="#handleSave" prefHeight="50.0" prefWidth="250.0" styleClass="submit-button" text="Enregistrer l'activité" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
