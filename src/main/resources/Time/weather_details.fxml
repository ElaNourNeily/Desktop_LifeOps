<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="450.0" style="-fx-background-color: linear-gradient(to bottom, #60a5fa, #3b82f6); -fx-background-radius: 30;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.Time.WeatherDetailsController">
   <children>
      <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" vbarPolicy="AS_NEEDED" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <content>
            <VBox spacing="20.0" style="-fx-background-color: transparent;">
               <children>
                  <!-- HEADER -->
                  <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-padding: 30 30 10 30;">
                     <children>
                        <Button mnemonicParsing="false" onAction="#handleClose" style="-fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 50; -fx-text-fill: white; -fx-font-size: 18; -fx-min-width: 40; -fx-min-height: 40; -fx-cursor: hand;" text="✕" />
                        <Region HBox.hgrow="ALWAYS" />
                        <VBox alignment="CENTER_RIGHT">
                           <children>
                              <Label fx:id="lblCity" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 20;" text="Tunis, TN" />
                              <Label fx:id="lblDate" style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 12;" text="Mercredi, 29 Avril" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>
      
                  <!-- CURRENT WEATHER -->
                  <VBox alignment="CENTER" spacing="5.0">
                     <children>
                        <Label fx:id="lblBigIcon" style="-fx-font-size: 80;" text="☀️" />
                        <Label fx:id="lblCurrentTemp" style="-fx-text-fill: white; -fx-font-size: 80; -fx-font-weight: bold;" text="24°">
                           <font>
                              <Font name="System Bold" size="80.0" />
                           </font>
                        </Label>
                        <Label fx:id="lblCondition" style="-fx-text-fill: white; -fx-font-size: 22; -fx-font-weight: bold;" text="Ciel Dégagé" />
                        <HBox alignment="CENTER" spacing="10.0">
                           <children>
                              <Label fx:id="lblHighLow" style="-fx-text-fill: rgba(255,255,255,0.9); -fx-font-size: 14;" text="H: 26°  L: 16°" />
                              <Label fx:id="lblFeelsLike" style="-fx-text-fill: rgba(255,255,255,0.9); -fx-font-size: 14;" text="|  Ressenti 24°" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
      
                  <!-- HOURLY FORECAST -->
                  <VBox spacing="15.0" style="-fx-background-color: rgba(255,255,255,0.15); -fx-background-radius: 25; -fx-padding: 20;">
                     <children>
                        <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13;" text="PRÉVISIONS HORAIRES" />
                        <ScrollPane fitToHeight="true" hbarPolicy="ALWAYS" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" vbarPolicy="NEVER">
                           <content>
                              <HBox fx:id="hboxHourly" spacing="25.0" style="-fx-padding: 0 0 10 0;">
                                 <!-- Hourly Items will be injected here -->
                              </HBox>
                           </content>
                        </ScrollPane>
                     </children>
                     <VBox.margin>
                        <Insets left="20.0" right="20.0" />
                     </VBox.margin>
                  </VBox>
      
                  <!-- DAILY FORECAST -->
                  <VBox spacing="15.0" style="-fx-background-color: rgba(255,255,255,0.15); -fx-background-radius: 25; -fx-padding: 20;">
                     <children>
                        <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13;" text="PRÉVISIONS SUR 7 JOURS" />
                        <VBox fx:id="vboxDaily" spacing="12.0">
                           <children>
                              <!-- Daily Items will be injected here -->
                           </children>
                        </VBox>
                     </children>
                     <VBox.margin>
                        <Insets bottom="20.0" left="20.0" right="20.0" />
                     </VBox.margin>
                  </VBox>
               </children>
            </VBox>
         </content>
      </ScrollPane>
   </children>
</AnchorPane>
