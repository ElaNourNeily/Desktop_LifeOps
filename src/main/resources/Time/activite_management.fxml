<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<AnchorPane prefHeight="800.0" prefWidth="1200.0"
            style="-fx-background-color: #17191F;"
            stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controller.Time.ActiviteManagementController">
   <children>
      <ScrollPane fitToWidth="true"
                  style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;"
                  AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                  AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <content>
            <VBox spacing="24.0" style="-fx-padding: 32 40 40 40;">
               <children>

                  <!-- Header -->
                  <HBox alignment="CENTER_LEFT">
                     <children>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                           <Label styleClass="badge-ai" text="GESTION" />
                           <Label style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"
                                  text="Activités" />
                           <Label style="-fx-text-fill: #8a8d91; -fx-font-size: 13px;"
                                  text="Gérez toutes vos activités planifiées" />
                        </VBox>
                     </children>
                  </HBox>

                  <!-- Sort + Search bar -->
                  <HBox alignment="CENTER_LEFT" spacing="8.0"
                        style="-fx-background-color: #17191F; -fx-background-radius: 14;
                               -fx-border-color: #2a2d32; -fx-border-width: 1; -fx-border-radius: 14; -fx-padding: 12 16;">
                     <children>
                        <Label style="-fx-text-fill: #a78bfa; -fx-font-weight: bold; -fx-font-size: 11;" text="⇅ Trier :" />
                        <Button fx:id="btnSortPrio" mnemonicParsing="false" onAction="#handleSortPriorite"
                                styleClass="action-button" text="🔥 Priorité" />
                        <Button fx:id="btnSortTime" mnemonicParsing="false" onAction="#handleSortHeure"
                                styleClass="action-button" text="🕒 Heure" />
                        <Button fx:id="btnSortEtat" mnemonicParsing="false" onAction="#handleSortEtat"
                                styleClass="action-button" text="📋 État" />
                        <Button fx:id="btnSortDuree" mnemonicParsing="false" onAction="#handleSortDuree"
                                styleClass="action-button" text="⏱ Durée" />
                        <Region HBox.hgrow="ALWAYS" />
                        <TextField fx:id="txtSearch" promptText="🔍 Rechercher..."
                                   styleClass="search-field" prefWidth="200" />
                        <Button mnemonicParsing="false" onAction="#handleResetSort"
                                styleClass="action-button" text="✕ Réinitialiser" />
                     </children>
                  </HBox>

                  <!-- Main content: table + form -->
                  <HBox spacing="24.0" VBox.vgrow="ALWAYS">
                     <children>

                        <!-- Table -->
                        <VBox HBox.hgrow="ALWAYS" spacing="0">
                           <TableView fx:id="activiteTable" VBox.vgrow="ALWAYS" prefHeight="500.0">
                              <columns>
                                 <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                                 <TableColumn fx:id="colTitre" prefWidth="200.0" text="Titre" />
                                 <TableColumn fx:id="colDuree" prefWidth="80.0" text="Durée" />
                                 <TableColumn fx:id="colEtat" prefWidth="110.0" text="État" />
                                 <TableColumn fx:id="colPlanningId" prefWidth="100.0" text="Planning" />
                              </columns>
                           </TableView>
                        </VBox>

                        <!-- Form panel -->
                        <VBox prefWidth="340.0" spacing="16.0"
                              style="-fx-background-color: #17191F; -fx-background-radius: 20;
                                     -fx-border-color: #2a2d32; -fx-border-width: 1; -fx-border-radius: 20; -fx-padding: 24;">
                           <children>
                              <Label style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"
                                     text="Détails de l'Activité" />

                              <VBox spacing="6.0">
                                 <Label styleClass="field-label" text="Titre" />
                                 <TextField fx:id="txtTitre" promptText="Titre de l'activité" styleClass="form-field" />
                              </VBox>
                              <HBox spacing="12.0">
                                 <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                    <Label styleClass="field-label" text="Durée (min)" />
                                    <TextField fx:id="txtDuree" promptText="60" styleClass="form-field" />
                                 </VBox>
                                 <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                    <Label styleClass="field-label" text="Priorité (1-5)" />
                                    <TextField fx:id="txtPriorite" promptText="1" styleClass="form-field" />
                                 </VBox>
                              </HBox>
                              <VBox spacing="6.0">
                                 <Label styleClass="field-label" text="État" />
                                 <ComboBox fx:id="comboEtat" maxWidth="Infinity" styleClass="form-choice"
                                           promptText="Sélectionner..." />
                              </VBox>
                              <HBox spacing="12.0">
                                 <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                    <Label styleClass="field-label" text="Début (HH:mm:ss)" />
                                    <TextField fx:id="txtHeureDebut" promptText="08:00:00" styleClass="form-field" />
                                 </VBox>
                                 <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                    <Label styleClass="field-label" text="Fin (HH:mm:ss)" />
                                    <TextField fx:id="txtHeureFin" promptText="09:00:00" styleClass="form-field" />
                                 </VBox>
                              </HBox>
                              <VBox spacing="6.0">
                                 <Label styleClass="field-label" text="Catégorie" />
                                 <TextField fx:id="txtCategorie" promptText="Travail, Santé..." styleClass="form-field" />
                              </VBox>
                              <VBox spacing="6.0">
                                 <Label styleClass="field-label" text="Planning" />
                                 <ComboBox fx:id="comboPlanning" maxWidth="Infinity" styleClass="form-choice" />
                              </VBox>

                              <!-- Color palette -->
                              <VBox spacing="8.0">
                                 <Label styleClass="field-label" text="Couleur" />
                                 <HBox spacing="8.0" alignment="CENTER_LEFT">
                                    <children>
                                       <Rectangle fx:id="selectedColorRect" width="28" height="28"
                                                  arcWidth="8" arcHeight="8" fill="#3498db" />
                                       <Label fx:id="selectedColorLabel"
                                              style="-fx-text-fill: #a1a1aa; -fx-font-size: 11;" text="#3498DB" />
                                    </children>
                                 </HBox>
                                 <FlowPane fx:id="colorPalette" hgap="6" vgap="6" prefWrapLength="280" />
                              </VBox>

                              <!-- Action buttons -->
                              <HBox spacing="8.0">
                                 <children>
                                    <Button mnemonicParsing="false" onAction="#handleAdd"
                                            styleClass="btn-primary" text="✚ Ajouter" HBox.hgrow="ALWAYS"
                                            maxWidth="Infinity" />
                                    <Button mnemonicParsing="false" onAction="#handleUpdate"
                                            styleClass="action-button" text="✎ Modifier" />
                                    <Button mnemonicParsing="false" onAction="#handleDelete"
                                            style="-fx-background-color: rgba(239,68,68,0.12); -fx-text-fill: #f87171;
                                                   -fx-border-color: rgba(239,68,68,0.3); -fx-border-width: 1;
                                                   -fx-border-radius: 10; -fx-background-radius: 10;
                                                   -fx-cursor: hand; -fx-padding: 8 14;"
                                            text="✕" />
                                 </children>
                              </HBox>
                              <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleClear"
                                      styleClass="action-button" text="↺ Effacer la sélection" />
                           </children>
                        </VBox>

                     </children>
                  </HBox>

               </children>
            </VBox>
         </content>
      </ScrollPane>
   </children>
</AnchorPane>
