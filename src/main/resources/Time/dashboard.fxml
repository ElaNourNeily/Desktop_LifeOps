<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<VBox spacing="0"
      style="-fx-background-color: #17191F;"
      stylesheets="@style.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controller.Time.DashboardController">

   <!-- ── Page header ─────────────────────────── -->
   <HBox alignment="CENTER_LEFT" style="-fx-padding: 32 40 20 40;">
      <VBox spacing="4" HBox.hgrow="ALWAYS">
         <Label styleClass="badge-ai" text="GESTION DU TEMPS" />
         <Label style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="⏱ Temps" />
         <Label style="-fx-text-fill: #8a8d91; -fx-font-size: 13px;" text="Planifiez, suivez et optimisez votre temps" />
      </VBox>
   </HBox>

   <!-- ── Sub-nav tabs ─────────────────────────── -->
   <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-padding: 0 40 16 40;">
      <Button mnemonicParsing="false" onAction="#handleHome"
              style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 8 20; -fx-cursor: hand; -fx-font-weight: bold;"
              text="🏠 Accueil" />
      <Button mnemonicParsing="false" onAction="#handleActivities"
              style="-fx-background-color: #1c1e24; -fx-text-fill: #8a8d91; -fx-background-radius: 8; -fx-padding: 8 20; -fx-cursor: hand;"
              text="📅 Calendrier" />
      <Button mnemonicParsing="false" onAction="#handlePlannings"
              style="-fx-background-color: #1c1e24; -fx-text-fill: #8a8d91; -fx-background-radius: 8; -fx-padding: 8 20; -fx-cursor: hand;"
              text="⚙ Plannings" />
      <Region HBox.hgrow="ALWAYS" />
      <Label fx:id="totalActivitiesLabel"
             style="-fx-text-fill: #6a6d71; -fx-font-size: 12px;" text="" />
   </HBox>

   <!-- ── Dynamic content area ─────────────────── -->
   <AnchorPane fx:id="contentArea" VBox.vgrow="ALWAYS"
               style="-fx-background-color: #17191F;" />

</VBox>
