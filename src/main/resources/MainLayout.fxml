<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="1200.0"
            style="-fx-background-color: #121417;"
            stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/19"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllers.MainLayoutController">

    <!-- NAVBAR GAUCHE -->
    <left>
        <VBox prefWidth="260.0"
              style="-fx-background-color: #0d0f12; -fx-border-color: #1c1e22; -fx-border-width: 0 1 0 0;"
              spacing="0">

            <!-- LOGO + NOM APP -->
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-padding: 25 20 20 20;">
                <ImageView fitWidth="38" fitHeight="38" preserveRatio="true">
                    <image>
                        <Image url="@assets/logo.png" />
                    </image>
                </ImageView>
                <Label text="LifeOps"
                       style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" />
            </HBox>

            <!-- MENU ITEMS -->
            <VBox spacing="4" style="-fx-padding: 10 12;">

                <HBox fx:id="menuTableauBord" onMouseClicked="#handleMenuClick"
                      alignment="CENTER_LEFT" spacing="14"
                      style="-fx-padding: 11 14; -fx-cursor: hand; -fx-background-radius: 8;">
                    <Label text="🏠" style="-fx-font-size: 17px;" />
                    <Label text="Tableau de bord"
                           style="-fx-text-fill: #8a8d91; -fx-font-size: 14px;" />
                </HBox>

                <HBox fx:id="menuTaches" onMouseClicked="#handleMenuClick"
                      alignment="CENTER_LEFT" spacing="14"
                      style="-fx-padding: 11 14; -fx-cursor: hand; -fx-background-radius: 8;">
                    <Label text="✔" style="-fx-font-size: 17px;" />
                    <Label text="Tâches"
                           style="-fx-text-fill: #8a8d91; -fx-font-size: 14px;" />
                </HBox>

                <HBox fx:id="menuFinance" onMouseClicked="#handleMenuClick"
                      alignment="CENTER_LEFT" spacing="14"
                      style="-fx-padding: 11 14; -fx-cursor: hand; -fx-background-radius: 8;">
                    <Label text="💰" style="-fx-font-size: 17px;" />
                    <Label text="Finance"
                           style="-fx-text-fill: #8a8d91; -fx-font-size: 14px;" />
                </HBox>

                <HBox fx:id="menuObjectifs" onMouseClicked="#handleMenuClick"
                      alignment="CENTER_LEFT" spacing="14"
                      style="-fx-padding: 11 14; -fx-cursor: hand; -fx-background-radius: 8;">
                    <Label text="🎯" style="-fx-font-size: 17px;" />
                    <Label text="Objectifs"
                           style="-fx-text-fill: #8a8d91; -fx-font-size: 14px;" />
                </HBox>

                <HBox fx:id="menuSante" onMouseClicked="#handleMenuClick"
                      alignment="CENTER_LEFT" spacing="14"
                      style="-fx-padding: 11 14; -fx-cursor: hand; -fx-background-radius: 8;">
                    <Label text="❤" style="-fx-font-size: 17px;" />
                    <Label text="Santé"
                           style="-fx-text-fill: #8a8d91; -fx-font-size: 14px;" />
                </HBox>

                <HBox fx:id="menuTemps" onMouseClicked="#handleMenuClick"
                      alignment="CENTER_LEFT" spacing="14"
                      style="-fx-padding: 11 14; -fx-cursor: hand; -fx-background-radius: 8;">
                    <Label text="🕐" style="-fx-font-size: 17px;" />
                    <Label text="Temps"
                           style="-fx-text-fill: #8a8d91; -fx-font-size: 14px;" />
                </HBox>

            </VBox>

            <!-- SPACER -->
            <Region VBox.vgrow="ALWAYS" />

            <!-- COMPTE (bas) -->
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-padding: 15 20; -fx-background-color: #16181b; -fx-border-color: #1c1e22; -fx-border-width: 1 0 0 0; -fx-cursor: hand;">
                <Label text="👤" style="-fx-font-size: 20px;" />
                <Label text="Compte"
                       style="-fx-text-fill: #8a8d91; -fx-font-size: 14px;" />
            </HBox>

        </VBox>
    </left>

    <!-- CONTENU CENTRAL -->
    <center>
        <StackPane fx:id="contentArea"
                   style="-fx-background-color: #121417;" />
    </center>

</BorderPane>
