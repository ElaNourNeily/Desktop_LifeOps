<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Group?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<StackPane prefHeight="850.0" prefWidth="421.0" style="-fx-background-color: #121417;"
           stylesheets="@../Task/board_style.css" xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.user.SignIn">

    <VBox alignment="CENTER" maxWidth="420.0" spacing="22.0" styleClass="login-card">

        <!-- Brand -->
        <VBox alignment="CENTER" spacing="8.0">
            <children>
                <Label style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: bold;" text="⚡ LifeOps"/>
                <Label style="-fx-background-color: rgba(139,92,246,0.15); -fx-text-fill: #a78bfa;                               -fx-background-radius: 999; -fx-padding: 3 14;                               -fx-font-size: 11px; -fx-font-weight: bold;"
                       text="Créer un compte"/>
                <Label styleClass="subtitle-label" text="Rejoignez LifeOps et prenez le contrôle"/>
            </children>
        </VBox>

        <!-- Form Fields -->
        <VBox maxWidth="340.0" spacing="12.0">
            <children>

                <!-- Prénom + Nom -->
                <HBox spacing="12.0">
                    <children>
                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                            <children>
                                <HBox>
                                    <children>
                                        <Label styleClass="form-label" text="PRÉNOM" />
                                        <Label fx:id="p" style="-fx-text-fill: #f87171; -fx-font-size: 10px;"
                                               text="Prénom invalide" visible="false">
                                            <HBox.margin><Insets left="8.0" /></HBox.margin>
                                        </Label>
                                    </children>
                                </HBox>
                                <TextField fx:id="prenom" promptText="John" styleClass="form-field" />
                            </children>
                        </VBox>
                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                            <children>
                                <HBox>
                                    <children>
                                        <Label styleClass="form-label" text="NOM" />
                                        <Label fx:id="nomerror" style="-fx-text-fill: #f87171; -fx-font-size: 10px;"
                                               text="Nom invalide" visible="false">
                                            <HBox.margin><Insets left="8.0" /></HBox.margin>
                                        </Label>
                                    </children>
                                </HBox>
                                <TextField fx:id="nom" promptText="Doe" styleClass="form-field" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <!-- Âge -->
                <VBox spacing="6.0">
                    <children>
                        <HBox>
                            <children>
                                <Label styleClass="form-label" text="ÂGE" />
                                <Label fx:id="ageerror" style="-fx-text-fill: #f87171; -fx-font-size: 10px;"
                                       text="Âge invalide" visible="false">
                                    <HBox.margin><Insets left="8.0" /></HBox.margin>
                                </Label>
                            </children>
                        </HBox>
                        <TextField fx:id="age" maxWidth="150.0" promptText="ex: 25" styleClass="form-field"/>
                    </children>
                </VBox>

                <!-- Téléphone -->
                <VBox spacing="6.0">
                    <children>
                        <HBox>
                            <children>
                                <Label styleClass="form-label" text="TÉLÉPHONE" />
                                <Label fx:id="phoneerror" style="-fx-text-fill: #f87171; -fx-font-size: 10px;"
                                       text="Numéro invalide" visible="false">
                                    <HBox.margin><Insets left="8.0" /></HBox.margin>
                                </Label>
                            </children>
                        </HBox>
                        <TextField fx:id="telephone" promptText="+216 12345678" styleClass="form-field"/>
                    </children>
                </VBox>

                <!-- Email -->
                <VBox spacing="6.0">
                    <children>
                        <HBox>
                            <children>
                                <Label styleClass="form-label" text="EMAIL" />
                                <Label fx:id="invalidmail" style="-fx-text-fill: #f87171; -fx-font-size: 10px;"
                                       text="Adresse e-mail invalide" visible="false">
                                    <HBox.margin><Insets left="8.0" /></HBox.margin>
                                </Label>
                            </children>
                        </HBox>
                        <TextField fx:id="email" promptText="john.doe@example.com" styleClass="form-field"/>
                    </children>
                </VBox>

                <!-- Mot de passe -->
                <VBox spacing="6.0">
                    <children>
                        <HBox>
                            <children>
                                <Label styleClass="form-label" text="MOT DE PASSE" />
                                <Label fx:id="pwdinvalid" style="-fx-text-fill: #f87171; -fx-font-size: 10px;"
                                       text="Format invalide" visible="false">
                                    <HBox.margin><Insets left="8.0" /></HBox.margin>
                                </Label>
                            </children>
                        </HBox>
                        <StackPane alignment="CENTER_RIGHT">
                            <PasswordField fx:id="password" maxWidth="Infinity" promptText="••••••••"
                                           styleClass="form-field"/>
                            <SVGPath
                                    content="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"
                                    fill="#6a6d71" scaleX="0.85" scaleY="0.85">
                                <StackPane.margin><Insets right="14.0" /></StackPane.margin>
                            </SVGPath>
                        </StackPane>
                    </children>
                </VBox>

                <!-- Captcha Section -->
                <VBox spacing="6.0">
                    <children>
                        <Label styleClass="form-label" text="SÉCURITÉ (CAPTCHA)"/>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Label fx:id="captchaLabel"
                                       style="-fx-text-fill: #a78bfa; -fx-font-size: 18px; -fx-font-family: 'Courier New'; -fx-font-weight: bold; -fx-background-color: #2a2d32; -fx-padding: 5 15; -fx-background-radius: 5;"
                                       text="XXXXXX"/>
                                <Button onAction="#refreshCaptcha"
                                        style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0;">
                                    <graphic>
                                        <SVGPath
                                                content="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"
                                                fill="#a78bfa" scaleX="0.8" scaleY="0.8"/>
                                    </graphic>
                                </Button>
                                <TextField fx:id="captchaInput" promptText="Code ici..." styleClass="form-field"
                                           HBox.hgrow="ALWAYS"/>
                            </children>
                        </HBox>
                        <Label fx:id="captchaError" style="-fx-text-fill: #f87171; -fx-font-size: 10px;"
                               text="Code captcha incorrect" visible="false"/>
                    </children>
                </VBox>

            </children>
        </VBox>

        <!-- Submit -->
        <Button maxWidth="340.0" onAction="#SignUp" styleClass="btn-primary" text="S'inscrire"/>

        <!-- Separator -->
        <HBox alignment="CENTER" maxWidth="340.0" spacing="10.0">
            <children>
                <Separator style="-fx-background-color: #2a2d32;" HBox.hgrow="ALWAYS"/>
                <Label style="-fx-text-fill: #6a6d71; -fx-font-size: 11px; -fx-font-weight: bold;"
                       text="OU S'INSCRIRE AVEC"/>
                <Separator style="-fx-background-color: #2a2d32;" HBox.hgrow="ALWAYS"/>
            </children>
        </HBox>

        <!-- Social Buttons -->
        <HBox alignment="CENTER" maxWidth="340.0" spacing="12.0">
            <children>
                <Button maxWidth="Infinity" onAction="#createwithgoogle" styleClass="action-button" HBox.hgrow="ALWAYS">
                    <graphic>
                        <Group>
                            <SVGPath content="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" />
                            <SVGPath content="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
                            <SVGPath content="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05" />
                            <SVGPath content="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
                        </Group>
                    </graphic>
                </Button>
                <Button maxWidth="Infinity" styleClass="action-button" HBox.hgrow="ALWAYS">
                    <graphic>
                        <SVGPath content="M12 2.04C6.5 2.04 2 6.53 2 12.06C2 17.06 5.66 21.21 10.44 21.96V14.96H7.9V12.06H10.44V9.85C10.44 7.34 11.93 5.96 14.22 5.96C15.31 5.96 16.45 6.15 16.45 6.15V8.62H15.19C13.95 8.62 13.56 9.39 13.56 10.18V12.06H16.34L15.89 14.96H13.56V21.96A10 10 0 0 0 22 12.06C22 6.53 17.5 2.04 12 2.04Z" fill="#1877F2" />
                    </graphic>
                </Button>
                <Button maxWidth="Infinity" styleClass="action-button" HBox.hgrow="ALWAYS">
                    <graphic>
                        <SVGPath content="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" fill="white" />
                    </graphic>
                </Button>
            </children>
        </HBox>

        <!-- Login link -->
        <HBox alignment="CENTER" spacing="6.0">
            <children>
                <Label styleClass="subtitle-label" text="Déjà un compte ?" />
                <Label onMouseClicked="#navtolog"
                       style="-fx-text-fill: #a78bfa; -fx-font-weight: bold; -fx-font-size: 13px; -fx-cursor: hand;"
                       text="Se connecter"/>
            </children>
        </HBox>

    </VBox>

</StackPane>
