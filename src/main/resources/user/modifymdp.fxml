<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="0"
      style="-fx-background-color: #171A21; -fx-padding: 40 50 40 50;"
      stylesheets="@../Task/board_style.css"
      xmlns="http://javafx.com/javafx/19"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.user.ModifyPasswordController">

    <!-- ── Page header ─────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="14">
        <Button onAction="#handleBack"
                style="-fx-background-color: #1c1e24; -fx-text-fill: #a78bfa;
                       -fx-border-color: #2a2d32; -fx-border-radius: 8;
                       -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 7 14;
                       -fx-font-size: 13px;"
                text="← Retour" />
        <VBox spacing="3">
            <Label style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"
                   text="Changer le mot de passe" />
            <Label style="-fx-text-fill: #8a8d91; -fx-font-size: 13px;"
                   text="Choisissez un nouveau mot de passe sécurisé" />
        </VBox>
    </HBox>

    <!-- ── Card ────────────────────────────────────── -->
    <VBox spacing="22"
          style="-fx-background-color: #1c1e24; -fx-background-radius: 16;
                 -fx-border-color: #2a2d32; -fx-border-width: 1; -fx-border-radius: 16;
                 -fx-padding: 32; -fx-max-width: 560;">
        <VBox.margin><Insets top="28" /></VBox.margin>

        <!-- Lock icon + title -->
        <HBox alignment="CENTER_LEFT" spacing="14">
            <Label style="-fx-font-size: 36px;">🔒</Label>
            <VBox spacing="3">
                <Label style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"
                       text="Sécurité du compte" />
                <Label style="-fx-text-fill: #8a8d91; -fx-font-size: 12px;"
                       text="Votre mot de passe doit contenir au moins 6 caractères" />
            </VBox>
        </HBox>

        <!-- Divider -->
        <Region style="-fx-background-color: #2a2d32; -fx-pref-height: 1; -fx-max-height: 1;" />

        <!-- Error label -->
        <Label fx:id="errorLabel" text="" visible="false" wrapText="true"
               style="-fx-text-fill: #f87171; -fx-font-size: 12px;
                      -fx-background-color: rgba(239,68,68,0.1);
                      -fx-background-radius: 8; -fx-padding: 8 14;" />

        <!-- Fields -->
        <VBox spacing="16">
            <VBox spacing="7">
                <Label styleClass="form-label" text="MOT DE PASSE ACTUEL" />
                <PasswordField fx:id="currentPasswordField"
                               promptText="Votre mot de passe actuel"
                               styleClass="form-field" maxWidth="480" />
            </VBox>
            <VBox spacing="7">
                <Label styleClass="form-label" text="NOUVEAU MOT DE PASSE" />
                <PasswordField fx:id="newPasswordField"
                               promptText="Minimum 6 caractères"
                               styleClass="form-field" maxWidth="480" />
            </VBox>
            <VBox spacing="7">
                <Label styleClass="form-label" text="CONFIRMER LE NOUVEAU MOT DE PASSE" />
                <PasswordField fx:id="confirmPasswordField"
                               promptText="Retapez le nouveau mot de passe"
                               styleClass="form-field" maxWidth="480" />
            </VBox>
        </VBox>

        <!-- Buttons -->
        <HBox spacing="12">
            <Button onAction="#handleConfirm" styleClass="btn-primary"
                    text="Confirmer le changement"
                    style="-fx-padding: 10 24;" />
        </HBox>

    </VBox>

</VBox>
