<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<StackPane prefHeight="700.0" prefWidth="500.0"
           style="-fx-background-color: #121417;"
           stylesheets="@../Task/board_style.css"
           xmlns="http://javafx.com/javafx/19"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="controller.user.ModifyPasswordController">

    <VBox alignment="CENTER" maxWidth="420.0" spacing="28.0" styleClass="login-card">

        <!-- Lock icon -->
        <SVGPath content="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM12 17c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1s3.1 1.39 3.1 3.1v2z"
                 fill="#a78bfa" scaleX="1.5" scaleY="1.5" />

        <!-- Header -->
        <VBox alignment="CENTER" spacing="8.0">
            <Label style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;"
                   text="Changer le mot de passe" />
            <Label styleClass="subtitle-label"
                   text="Choisissez un nouveau mot de passe sécurisé"
                   wrapText="true" />
        </VBox>

        <!-- Error label -->
        <Label fx:id="errorLabel"
               style="-fx-text-fill: #f87171; -fx-font-size: 11px;
                      -fx-background-color: rgba(239,68,68,0.1);
                      -fx-background-radius: 6; -fx-padding: 6 10;"
               text="" visible="false" wrapText="true" maxWidth="340.0" />

        <!-- Fields -->
        <VBox spacing="14.0" maxWidth="340.0">
            <VBox spacing="6.0">
                <Label styleClass="form-label" text="MOT DE PASSE ACTUEL" />
                <PasswordField fx:id="currentPasswordField"
                               promptText="Votre mot de passe actuel"
                               styleClass="form-field" />
            </VBox>
            <VBox spacing="6.0">
                <Label styleClass="form-label" text="NOUVEAU MOT DE PASSE" />
                <PasswordField fx:id="newPasswordField"
                               promptText="Minimum 6 caractères"
                               styleClass="form-field" />
            </VBox>
            <VBox spacing="6.0">
                <Label styleClass="form-label" text="CONFIRMER LE NOUVEAU MOT DE PASSE" />
                <PasswordField fx:id="confirmPasswordField"
                               promptText="Retapez le nouveau mot de passe"
                               styleClass="form-field" />
            </VBox>
        </VBox>

        <!-- Buttons -->
        <VBox spacing="10.0" maxWidth="340.0">
            <Button maxWidth="Infinity" onAction="#handleConfirm"
                    styleClass="btn-primary" text="Confirmer" />
            <Button maxWidth="Infinity" onAction="#handleBack"
                    style="-fx-background-color: transparent; -fx-text-fill: #6a6d71;
                           -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 6 0;"
                    text="Retour" />
        </VBox>

    </VBox>

</StackPane>
