<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" style="-fx-background: #171A21; -fx-background-color: transparent;"
            stylesheets="@../Task/board_style.css" xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.user.EditUserController">

    <VBox spacing="0" style="-fx-background-color: #171A21; -fx-padding: 40 50 40 50;">

        <!-- ── Page header ─────────────────────────────── -->
        <VBox spacing="4">
            <Label style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="Mon Profil"/>
            <Label style="-fx-text-fill: #8a8d91; -fx-font-size: 13px;" text="Gérez vos informations personnelles"/>
        </VBox>

        <!-- ── Feedback banner ─────────────────────────── -->
        <Label fx:id="messageLabel" maxWidth="560.0"
               style="-fx-font-size: 12px; -fx-background-radius: 8; -fx-padding: 8 14;" text="" visible="false"
               wrapText="true">
            <VBox.margin><Insets top="20" /></VBox.margin>
        </Label>

        <!-- ── Profile card ────────────────────────────── -->
        <VBox spacing="24"
              style="-fx-background-color: #1c1e24; -fx-background-radius: 16;                      -fx-border-color: #2a2d32; -fx-border-width: 1; -fx-border-radius: 16;                      -fx-padding: 32;">
            <VBox.margin><Insets top="28" /></VBox.margin>

            <!-- Avatar row -->
            <HBox alignment="CENTER_LEFT" spacing="20">
                <Label style="-fx-font-size: 52px;">👤</Label>
                <VBox spacing="4">
                    <Label fx:id="displayNameLabel"
                           style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="—"/>
                    <Label fx:id="displayEmailLabel" style="-fx-text-fill: #6a6d71; -fx-font-size: 13px;" text="—"/>
                    <Label fx:id="displayRoleLabel"
                           style="-fx-background-color: rgba(139,92,246,0.15); -fx-text-fill: #a78bfa;                                   -fx-background-radius: 999; -fx-padding: 2 10;                                   -fx-font-size: 11px; -fx-font-weight: bold;"
                           text="ROLE_USER"/>
                </VBox>
            </HBox>

            <!-- Divider -->
            <Region style="-fx-background-color: #2a2d32; -fx-pref-height: 1; -fx-max-height: 1;" />

            <!-- Form grid -->
            <VBox spacing="18">

                <!-- Prénom + Nom -->
                <HBox spacing="20">
                    <VBox spacing="7" HBox.hgrow="ALWAYS">
                        <Label styleClass="form-label" text="PRÉNOM" />
                        <TextField fx:id="prenomField" maxWidth="Infinity" promptText="Prénom" styleClass="form-field"/>
                    </VBox>
                    <VBox spacing="7" HBox.hgrow="ALWAYS">
                        <Label styleClass="form-label" text="NOM" />
                        <TextField fx:id="nomField" maxWidth="Infinity" promptText="Nom" styleClass="form-field"/>
                    </VBox>
                </HBox>

                <!-- Âge + Téléphone -->
                <HBox spacing="20">
                    <VBox spacing="7" HBox.hgrow="ALWAYS">
                        <Label styleClass="form-label" text="ÂGE" />
                        <TextField fx:id="ageField" maxWidth="Infinity" promptText="ex: 25" styleClass="form-field"/>
                    </VBox>
                    <VBox spacing="7" HBox.hgrow="ALWAYS">
                        <Label styleClass="form-label" text="TÉLÉPHONE" />
                        <TextField fx:id="telephoneField" maxWidth="Infinity" promptText="+216 12345678"
                                   styleClass="form-field"/>
                    </VBox>
                </HBox>

                <!-- Email (read-only) -->
                <VBox spacing="7">
                    <Label styleClass="form-label" text="EMAIL (non modifiable)" />
                    <TextField fx:id="emailField" editable="false"
                               style="-fx-background-color: #0B0C10; -fx-text-fill: #6a6d71;                                       -fx-background-radius: 9; -fx-border-color: #1e2028;                                       -fx-border-width: 1; -fx-border-radius: 9; -fx-padding: 9 12;"
                               styleClass="form-field"/>
                </VBox>

            </VBox>

            <!-- Action buttons -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Button onAction="#handleSave" style="-fx-padding: 10 24;" styleClass="btn-primary"
                        text="Enregistrer les modifications"/>
                <Button onAction="#handleChangePassword"
                        style="-fx-background-color: transparent; -fx-text-fill: #a78bfa;                                -fx-border-color: rgba(139,92,246,0.4); -fx-border-radius: 10;                                -fx-background-radius: 10; -fx-font-size: 13px; -fx-cursor: hand;                                -fx-padding: 10 20; -fx-font-weight: bold;"
                        text="🔒 Changer le mot de passe"/>
            </HBox>

        </VBox>

    </VBox>

</ScrollPane>
