<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="660.0" prefWidth="680.0" style="-fx-background-color: #121417;"
            stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/19"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllers.PlanActionController">
    <padding>
        <Insets bottom="20" left="25" right="25" top="20" />
    </padding>

    <!-- HEADER -->
    <top>
        <VBox spacing="4">
            <Label fx:id="labelTitreObjectif" style="-fx-text-fill: #8a8d91; -fx-font-size: 13px;" text="Objectif :" />
            <Label styleClass="title-label" text="Plans d'action" />
            <Separator style="-fx-background-color: #2a2d32;" />
            <BorderPane.margin>
                <Insets bottom="10" />
            </BorderPane.margin>
        </VBox>
    </top>

    <center>
        <VBox spacing="12">

            <!-- LISTE DES PLANS -->
            <ScrollPane fitToWidth="true" prefHeight="260.0"
                        style="-fx-background: #121417; -fx-background-color: transparent;">
                <VBox fx:id="plansContainer" spacing="10" />
            </ScrollPane>

            <Separator style="-fx-background-color: #2a2d32;" />

            <!-- BOUTON SUGGESTIONS IA -->
            <HBox alignment="CENTER_RIGHT">
                <Button fx:id="btnSuggestions" onAction="#handleSuggestionsIA"
                        text="✨ Suggestions IA"
                        style="-fx-background-color: linear-gradient(to right, #7c3aed, #a78bfa);
                               -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px;
                               -fx-background-radius: 20; -fx-padding: 8 20; -fx-cursor: hand;" />
            </HBox>

            <!-- FORMULAIRE AJOUT / MODIFICATION -->
            <Label fx:id="labelFormTitre" style="-fx-text-fill: #a78bfa; -fx-font-weight: bold; -fx-font-size: 14px;" text="➕ Nouveau plan d'action" />

            <!-- Titre + Priorité + Statut -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <TextField fx:id="txtTitre" promptText="Titre du plan *"
                               styleClass="form-field" maxWidth="Infinity" />
                    <Label fx:id="errTitre" style="-fx-text-fill: #ff477e; -fx-font-size: 11px;" text="" visible="false" />
                </VBox>
                <ComboBox fx:id="comboPriorite" promptText="Priorité"
                          styleClass="combo-form"
                          style="-fx-pref-width: 120;" />
                <ComboBox fx:id="comboStatut" promptText="Statut"
                          styleClass="combo-form"
                          style="-fx-pref-width: 120;" />
            </HBox>

            <!-- Description -->
            <TextArea fx:id="txtDescription" promptText="Description (optionnelle)" prefRowCount="2"
                      style="-fx-control-inner-background: #2a2d32; -fx-text-fill: white;
                             -fx-prompt-text-fill: #6a6d71; -fx-border-color: #3a3d42;
                             -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8;
                             -fx-font-size: 13px;" />

            <!-- Dates -->
            <HBox spacing="15">
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label styleClass="form-label" text="Date de début *" />
                    <DatePicker fx:id="dateDebut" maxWidth="Infinity" styleClass="date-form" />
                    <Label fx:id="errDateDebut" style="-fx-text-fill: #ff477e; -fx-font-size: 11px;" text="" visible="false" />
                </VBox>
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label styleClass="form-label" text="Date de fin *" />
                    <DatePicker fx:id="dateFin" maxWidth="Infinity" styleClass="date-form" />
                    <Label fx:id="errDateFin" style="-fx-text-fill: #ff477e; -fx-font-size: 11px;" text="" visible="false" />
                </VBox>
            </HBox>

            <!-- Boutons -->
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button fx:id="btnAnnuler" onAction="#handleAnnuler"
                        style="-fx-background-color: #2a2d32; -fx-text-fill: #8a8d91; -fx-background-radius: 20; -fx-padding: 8 16; -fx-cursor: hand;"
                        text="Annuler" visible="false" managed="false" />
                <Button fx:id="btnSauvegarder" onAction="#handleSauvegarder"
                        styleClass="btn-primary" text="Enregistrer" />
            </HBox>

        </VBox>
    </center>
</BorderPane>
