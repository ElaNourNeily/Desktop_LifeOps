<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="718.0" prefWidth="1053.0" style="-fx-background-color: #0f172a;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.HealthArticlesController">
   <children>
      <VBox spacing="25.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <padding><Insets bottom="30.0" left="40.0" right="40.0" top="30.0" /></padding>
         <children>
            <!-- Header avec bouton retour -->
            <HBox alignment="CENTER_LEFT" spacing="20.0">
               <children>
                  <Button onAction="#goBack" style="-fx-background-color: #1e293b; -fx-text-fill: #94a3b8; -fx-background-radius: 5; -fx-cursor: hand;" text="&lt; Retour" />
                  <Label text="Bibliothèque de Prévention Santé" textFill="WHITE">
                     <font><Font name="System Bold" size="28.0" /></font>
                  </Label>
               </children>
            </HBox>

            <!-- Barre de recherche stylisée -->
            <HBox spacing="15.0">
               <children>
                  <TextField fx:id="searchField" prefHeight="45.0" prefWidth="400.0" promptText="Rechercher (ex: nutrition, heart, sleep...)" style="-fx-background-color: #1e293b; -fx-text-fill: white; -fx-prompt-text-fill: #64748b; -fx-background-radius: 25; -fx-padding: 0 20; -fx-border-color: #334155; -fx-border-radius: 25;" HBox.hgrow="ALWAYS" />
                  <Button onAction="#searchArticles" prefHeight="45.0" prefWidth="150.0" style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-background-radius: 25; -fx-font-weight: bold; -fx-cursor: hand;" text="Découvrir" />
               </children>
            </HBox>

            <!-- Titre de section -->
            <Label fx:id="lblResultCount" text="Explorez les articles de santé publique" textFill="#c4b5fd">
               <font><Font size="16.0" /></font>
            </Label>

            <!-- Container des articles -->
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
               <content>
                  <VBox fx:id="articlesContainer" spacing="15.0" style="-fx-padding: 10 5 10 0;">
                     <!-- Les cartes d'articles seront injectées ici -->
                  </VBox>
               </content>
            </ScrollPane>
         </children>
      </VBox>
   </children>
</AnchorPane>
