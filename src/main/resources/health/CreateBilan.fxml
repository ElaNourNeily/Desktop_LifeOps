<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="0"
      style="-fx-background-color: #171A21; -fx-padding: 32 40 40 40;"
      stylesheets="@../../Task/board_style.css"
      xmlns="http://javafx.com/javafx/19"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controller.health.CreateBilanController">

    <HBox alignment="CENTER_LEFT" spacing="14">
        <Button onAction="#goBack"
                style="-fx-background-color: #1c1e24; -fx-text-fill: #a78bfa; -fx-border-color: #2a2d32;
                       -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 7 14;"
                text="← Retour" />
        <VBox spacing="3">
            <Label style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" text="🪄 Bilan IA" />
            <Label style="-fx-text-fill: #8a8d91; -fx-font-size: 13px;"
                   text="L'IA analyse vos suivis et génère un bilan de santé complet" />
        </VBox>
    </HBox>

    <Label fx:id="statusLabel" text="" visible="false" wrapText="true" maxWidth="560">
        <VBox.margin><Insets top="16" /></VBox.margin>
    </Label>

    <VBox spacing="20"
          style="-fx-background-color: #1c1e24; -fx-background-radius: 16;
                 -fx-border-color: rgba(139,92,246,0.3); -fx-border-width: 1; -fx-border-radius: 16; -fx-padding: 28; -fx-max-width: 560;">
        <VBox.margin><Insets top="24" /></VBox.margin>

        <Label style="-fx-text-fill: #a78bfa; -fx-font-size: 14px; -fx-font-weight: bold;" text="Sélectionnez la période à analyser" />

        <HBox spacing="20">
            <VBox spacing="7" HBox.hgrow="ALWAYS">
                <Label styleClass="form-label" text="DATE DE DÉBUT" />
                <DatePicker fx:id="dateDebutPicker" styleClass="form-field" maxWidth="Infinity" />
            </VBox>
            <VBox spacing="7" HBox.hgrow="ALWAYS">
                <Label styleClass="form-label" text="DATE DE FIN" />
                <DatePicker fx:id="dateFinPicker" styleClass="form-field" maxWidth="Infinity" />
            </VBox>
        </HBox>

        <Label style="-fx-text-fill: #6a6d71; -fx-font-size: 12px;"
               text="L'IA analysera tous vos suivis dans cette période et générera automatiquement le score de forme, le niveau de stress, la fatigue et les recommandations personnalisées."
               wrapText="true" />

        <HBox spacing="12" alignment="CENTER_RIGHT">
            <Button onAction="#goBack"
                    style="-fx-background-color: transparent; -fx-text-fill: #6a6d71; -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 9 16;"
                    text="Annuler" />
            <Button onAction="#saveBilan" styleClass="btn-primary" text="🪄 Générer le bilan" style="-fx-padding: 10 24;" />
        </HBox>
    </VBox>
</VBox>
