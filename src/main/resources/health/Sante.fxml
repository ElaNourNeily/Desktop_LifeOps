<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="0"
      style="-fx-background-color: #171A21;"
      stylesheets="@../../Task/board_style.css"
      xmlns="http://javafx.com/javafx/19"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controller.health.SanteController">

    <!-- ── Page header ─────────────────────────── -->
    <HBox alignment="CENTER_LEFT" style="-fx-padding: 32 40 20 40;">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="❤ Santé" />
            <Label style="-fx-text-fill: #8a8d91; -fx-font-size: 13px;" text="Suivez votre bien-être et analysez vos habitudes" />
        </VBox>
        <!-- Context-aware primary action — changes label when switching tabs -->
        <Button fx:id="btnActionPrimary" onAction="#openCreate"
                styleClass="btn-primary"
                text="+ Nouveau suivi"
                style="-fx-padding: 9 18;" />
    </HBox>

    <!-- ── Tabs + secondary actions ───────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-padding: 0 40 16 40;">
        <Button fx:id="btnTabSuivi" onAction="#showSuivis"
                style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 8 20; -fx-cursor: hand; -fx-font-weight: bold;"
                text="Mes Suivis" />
        <Button fx:id="btnTabBilan" onAction="#showBilans"
                style="-fx-background-color: #1c1e24; -fx-text-fill: #8a8d91; -fx-background-radius: 8; -fx-padding: 8 20; -fx-cursor: hand;"
                text="Mes Bilans" />
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#openDashboard"
                style="-fx-background-color: rgba(139,92,246,0.15); -fx-text-fill: #a78bfa;
                       -fx-border-color: rgba(139,92,246,0.3); -fx-border-radius: 10; -fx-background-radius: 10;
                       -fx-font-size: 12px; -fx-cursor: hand; -fx-padding: 7 14; -fx-font-weight: bold;"
                text="📈 Dashboard IA" />
        <Button onAction="#openDrugSearch"
                style="-fx-background-color: #1c1e24; -fx-text-fill: #8a8d91;
                       -fx-border-color: #2a2d32; -fx-border-radius: 10; -fx-background-radius: 10;
                       -fx-font-size: 12px; -fx-cursor: hand; -fx-padding: 7 14;"
                text="💊 Médicaments" />
        <Button onAction="#openHealthArticles"
                style="-fx-background-color: #1c1e24; -fx-text-fill: #8a8d91;
                       -fx-border-color: #2a2d32; -fx-border-radius: 10; -fx-background-radius: 10;
                       -fx-font-size: 12px; -fx-cursor: hand; -fx-padding: 7 14;"
                text="📚 Articles" />
    </HBox>

    <!-- ── Filter bars ─────────────────────────── -->
    <HBox fx:id="suiviFilterBar" alignment="CENTER_LEFT" spacing="8" style="-fx-padding: 0 40 12 40;">
        <Label style="-fx-text-fill: #6a6d71; -fx-font-size: 11px; -fx-font-weight: bold;" text="TRIER PAR :" />
        <Button fx:id="btnFilterJour" onAction="#filterByJour"
                style="-fx-background-color: #1c1e24; -fx-text-fill: #8a8d91; -fx-background-radius: 8; -fx-padding: 6 14; -fx-cursor: hand;"
                text="Aujourd'hui" />
        <Button fx:id="btnFilterMois" onAction="#filterByMois"
                style="-fx-background-color: #1c1e24; -fx-text-fill: #8a8d91; -fx-background-radius: 8; -fx-padding: 6 14; -fx-cursor: hand;"
                text="Ce mois" />
        <Button fx:id="btnFilterAnnee" onAction="#filterByAnnee"
                style="-fx-background-color: #1c1e24; -fx-text-fill: #8a8d91; -fx-background-radius: 8; -fx-padding: 6 14; -fx-cursor: hand;"
                text="Cette année" />
        <Button onAction="#resetFilters"
                style="-fx-background-color: transparent; -fx-text-fill: #6a6d71; -fx-font-size: 12px; -fx-cursor: hand; -fx-padding: 6 10;"
                text="Tout voir" />
    </HBox>

    <HBox fx:id="bilanFilterBar" alignment="CENTER_LEFT" spacing="8"
          style="-fx-padding: 0 40 12 40;" visible="false" managed="false">
        <Button fx:id="btnToggleBurnout" onAction="#toggleBurnoutFilter"
                style="-fx-background-color: transparent; -fx-text-fill: #ef4444;
                       -fx-border-color: rgba(239,68,68,0.4); -fx-border-radius: 20;
                       -fx-background-radius: 20; -fx-padding: 6 14; -fx-cursor: hand;"
                text="⚠️ Risques de burnout" />
    </HBox>

    <!-- ── Content ─────────────────────────────── -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background: #171A21; -fx-background-color: transparent;">
        <VBox spacing="0" style="-fx-padding: 0 40 40 40;">
            <VBox fx:id="santeListContainer" spacing="12" />
            <VBox fx:id="bilanListContainer" spacing="12" visible="false" managed="false" />
        </VBox>
    </ScrollPane>

</VBox>
