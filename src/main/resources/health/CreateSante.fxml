<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true"
            style="-fx-background: #171A21; -fx-background-color: transparent;"
            stylesheets="@../../Task/board_style.css"
            xmlns="http://javafx.com/javafx/19"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controller.health.CreateSanteController">

    <VBox spacing="0" style="-fx-background-color: #171A21; -fx-padding: 32 40 40 40;">

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="14">
            <Button onAction="#goBack"
                    style="-fx-background-color: #1c1e24; -fx-text-fill: #a78bfa; -fx-border-color: #2a2d32;
                           -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 7 14;"
                    text="← Retour" />
            <VBox spacing="3">
                <Label style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" text="Nouveau Suivi Santé" />
                <Label style="-fx-text-fill: #8a8d91; -fx-font-size: 13px;" text="Enregistrez vos indicateurs du jour" />
            </VBox>
        </HBox>

        <!-- Error label -->
        <Label fx:id="errorLabel" text="" visible="false" wrapText="true"
               style="-fx-text-fill: #f87171; -fx-font-size: 12px; -fx-background-color: rgba(239,68,68,0.1);
                      -fx-background-radius: 8; -fx-padding: 8 14;">
            <VBox.margin><Insets top="16" /></VBox.margin>
        </Label>

        <!-- Form card -->
        <VBox spacing="20"
              style="-fx-background-color: #1c1e24; -fx-background-radius: 16;
                     -fx-border-color: #2a2d32; -fx-border-width: 1; -fx-border-radius: 16; -fx-padding: 28;">
            <VBox.margin><Insets top="24" /></VBox.margin>

            <!-- Date -->
            <VBox spacing="7">
                <Label styleClass="form-label" text="DATE DU SUIVI" />
                <DatePicker fx:id="datePicker" styleClass="form-field" maxWidth="240" />
            </VBox>

            <!-- Sommeil + Qualité -->
            <HBox spacing="20">
                <VBox spacing="7" HBox.hgrow="ALWAYS">
                    <Label styleClass="form-label" text="HEURES DE SOMMEIL" />
                    <TextField fx:id="sommeilField" promptText="Ex: 7.5" styleClass="form-field" maxWidth="Infinity" />
                </VBox>
                <VBox spacing="7" HBox.hgrow="ALWAYS">
                    <Label styleClass="form-label" text="QUALITÉ SOMMEIL (1-5)" />
                    <ChoiceBox fx:id="qualiteSommeilBox" maxWidth="Infinity" styleClass="combo-form" />
                </VBox>
            </HBox>

            <!-- Eau + Activité min -->
            <HBox spacing="20">
                <VBox spacing="7" HBox.hgrow="ALWAYS">
                    <Label styleClass="form-label" text="VERRES D'EAU" />
                    <TextField fx:id="eauField" promptText="Ex: 8" styleClass="form-field" maxWidth="Infinity" />
                </VBox>
                <VBox spacing="7" HBox.hgrow="ALWAYS">
                    <Label styleClass="form-label" text="MINUTES D'ACTIVITÉ" />
                    <TextField fx:id="activiteMinField" promptText="Ex: 45" styleClass="form-field" maxWidth="Infinity" />
                </VBox>
            </HBox>

            <!-- Poids + Humeur -->
            <HBox spacing="20">
                <VBox spacing="7" HBox.hgrow="ALWAYS">
                    <Label styleClass="form-label" text="POIDS (KG)" />
                    <TextField fx:id="poidsField" promptText="Ex: 70.0" styleClass="form-field" maxWidth="Infinity" />
                </VBox>
                <VBox spacing="7" HBox.hgrow="ALWAYS">
                    <Label styleClass="form-label" text="HUMEUR (1-5)" />
                    <ChoiceBox fx:id="humeurBox" maxWidth="Infinity" styleClass="combo-form" />
                </VBox>
            </HBox>

            <!-- Activité type -->
            <VBox spacing="7">
                <Label styleClass="form-label" text="TYPE D'ACTIVITÉ" />
                <TextField fx:id="activiteTypeField" promptText="Ex: Course à pied, Natation..." styleClass="form-field" />
            </VBox>

            <!-- Notes -->
            <VBox spacing="7">
                <Label styleClass="form-label" text="NOTES" />
                <TextField fx:id="notesField" promptText="Remarques..." styleClass="form-field" />
            </VBox>

            <!-- Buttons -->
            <HBox spacing="12" alignment="CENTER_RIGHT">
                <Button onAction="#goBack"
                        style="-fx-background-color: transparent; -fx-text-fill: #6a6d71; -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 9 16;"
                        text="Annuler" />
                <Button onAction="#saveSuiviSante" styleClass="btn-primary" text="Enregistrer" style="-fx-padding: 10 24;" />
            </HBox>
        </VBox>
    </VBox>
</ScrollPane>
