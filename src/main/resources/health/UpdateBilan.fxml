<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true"
            style="-fx-background: #171A21; -fx-background-color: transparent;"
            stylesheets="@../../Task/board_style.css"
            xmlns="http://javafx.com/javafx/19"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controller.health.UpdateBilanController">

    <VBox spacing="0" style="-fx-background-color: #171A21; -fx-padding: 32 40 40 40;">

        <HBox alignment="CENTER_LEFT" spacing="14">
            <Button onAction="#goBack"
                    style="-fx-background-color: #1c1e24; -fx-text-fill: #a78bfa; -fx-border-color: #2a2d32;
                           -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 7 14;"
                    text="← Retour" />
            <VBox spacing="3">
                <Label style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" text="Modifier le Bilan" />
                <Label style="-fx-text-fill: #8a8d91; -fx-font-size: 13px;" text="Mettez à jour votre évaluation de santé" />
            </VBox>
        </HBox>

        <Label fx:id="errorLabel" text="" visible="false" wrapText="true"
               style="-fx-text-fill: #f87171; -fx-font-size: 12px; -fx-background-color: rgba(239,68,68,0.1);
                      -fx-background-radius: 8; -fx-padding: 8 14;">
            <VBox.margin><Insets top="16" /></VBox.margin>
        </Label>

        <VBox spacing="20"
              style="-fx-background-color: #1c1e24; -fx-background-radius: 16;
                     -fx-border-color: #2a2d32; -fx-border-width: 1; -fx-border-radius: 16; -fx-padding: 28;">
            <VBox.margin><Insets top="24" /></VBox.margin>

            <HBox spacing="20">
                <VBox spacing="7" HBox.hgrow="ALWAYS">
                    <Label styleClass="form-label" text="DATE DE DÉBUT" />
                    <DatePicker fx:id="dateDebutPicker" styleClass="form-field" maxWidth="Infinity" />
                </VBox>
                <VBox spacing="7" HBox.hgrow="ALWAYS">
                    <Label styleClass="form-label" text="DATE DE FIN" />
                    <DatePicker fx:id="dateFinPicker" styleClass="form-field" maxWidth="Infinity" />
                </VBox>
            </HBox>
            <HBox spacing="20">
                <VBox spacing="7" HBox.hgrow="ALWAYS">
                    <Label styleClass="form-label" text="NIVEAU FATIGUE (1-5)" />
                    <ChoiceBox fx:id="fatigueBox" maxWidth="Infinity" styleClass="combo-form" />
                </VBox>
                <VBox spacing="7" HBox.hgrow="ALWAYS">
                    <Label styleClass="form-label" text="NIVEAU STRESS (1-5)" />
                    <ChoiceBox fx:id="stressBox" maxWidth="Infinity" styleClass="combo-form" />
                </VBox>
            </HBox>
            <HBox spacing="20">
                <VBox spacing="7" HBox.hgrow="ALWAYS">
                    <Label styleClass="form-label" text="SCORE DE FORME (0-10)" />
                    <TextField fx:id="scoreField" promptText="Ex: 7.5" styleClass="form-field" maxWidth="Infinity" />
                </VBox>
                <VBox spacing="7" HBox.hgrow="ALWAYS">
                    <Label styleClass="form-label" text="RISQUE BURNOUT" />
                    <CheckBox fx:id="burnoutCheckBox" text="Oui"
                              style="-fx-text-fill: #f87171; -fx-font-size: 13px; -fx-cursor: hand;" />
                </VBox>
            </HBox>
            <VBox spacing="7">
                <Label styleClass="form-label" text="RECOMMANDATIONS" />
                <TextField fx:id="recommandationsField" promptText="Recommandations..." styleClass="form-field" />
            </VBox>

            <HBox spacing="12" alignment="CENTER_RIGHT">
                <Button onAction="#deleteBilan"
                        style="-fx-background-color: transparent; -fx-text-fill: #f87171;
                               -fx-border-color: rgba(239,68,68,0.4); -fx-border-radius: 10;
                               -fx-background-radius: 10; -fx-cursor: hand; -fx-padding: 9 16;"
                        text="🗑 Supprimer" />
                <Button onAction="#updateBilan" styleClass="btn-primary" text="💾 Sauvegarder" style="-fx-padding: 10 24;" />
            </HBox>
        </VBox>
    </VBox>
</ScrollPane>
