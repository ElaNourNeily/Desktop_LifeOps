<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="480.0" spacing="18.0"
      styleClass="popup-card"
      xmlns="http://javafx.com/javafx/19"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controller.health.UpdateBilanController">

    <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>

    <!-- Header -->
    <VBox spacing="4.0">
        <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Modifier le Bilan" />
        <Label styleClass="popup-subtitle" text="Mettez à jour votre évaluation de santé" />
    </VBox>

    <!-- Error -->
    <Label fx:id="errorLabel" text="" visible="false" wrapText="true"
           style="-fx-text-fill: #f87171; -fx-font-size: 11px;
                  -fx-background-color: rgba(239,68,68,0.1); -fx-background-radius: 6; -fx-padding: 6 10;" />

    <!-- Dates -->
    <HBox spacing="16.0">
        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
            <Label styleClass="panel-section-title" text="DATE DE DÉBUT" />
            <DatePicker fx:id="dateDebutPicker" maxWidth="Infinity" styleClass="form-field" />
        </VBox>
        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
            <Label styleClass="panel-section-title" text="DATE DE FIN" />
            <DatePicker fx:id="dateFinPicker" maxWidth="Infinity" styleClass="form-field" />
        </VBox>
    </HBox>

    <!-- Fatigue + Stress -->
    <HBox spacing="16.0">
        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
            <Label styleClass="panel-section-title" text="NIVEAU FATIGUE (1-5)" />
            <ChoiceBox fx:id="fatigueBox" maxWidth="Infinity" styleClass="combo-form" />
        </VBox>
        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
            <Label styleClass="panel-section-title" text="NIVEAU STRESS (1-5)" />
            <ChoiceBox fx:id="stressBox" maxWidth="Infinity" styleClass="combo-form" />
        </VBox>
    </HBox>

    <!-- Score + Burnout -->
    <HBox spacing="16.0">
        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
            <Label styleClass="panel-section-title" text="SCORE DE FORME (0-10)" />
            <TextField fx:id="scoreField" promptText="Ex: 7.5" styleClass="form-field" maxWidth="Infinity" />
        </VBox>
        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
            <Label styleClass="panel-section-title" text="RISQUE BURNOUT" />
            <CheckBox fx:id="burnoutCheckBox" text="Oui"
                      style="-fx-text-fill: #f87171; -fx-font-size: 13px; -fx-cursor: hand;" />
        </VBox>
    </HBox>

    <!-- Recommandations -->
    <VBox spacing="6.0">
        <Label styleClass="panel-section-title" text="RECOMMANDATIONS" />
        <TextField fx:id="recommandationsField" promptText="Recommandations..." styleClass="form-field" />
    </VBox>

    <!-- Buttons -->
    <HBox alignment="CENTER_RIGHT" spacing="12.0">
        <Button onAction="#handleDelete"
                style="-fx-background-color: transparent; -fx-text-fill: #f87171; -fx-cursor: hand;
                       -fx-padding: 8 14;" text="🗑 Supprimer" />
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#handleClose"
                style="-fx-background-color: transparent; -fx-text-fill: #8a8d91; -fx-cursor: hand;
                       -fx-padding: 8 14; -fx-border-color: #2a2d32; -fx-border-width: 1;
                       -fx-border-radius: 10; -fx-background-radius: 10;"
                text="Annuler" />
        <Button onAction="#updateBilan" styleClass="btn-primary" text="💾 Sauvegarder" />
    </HBox>

</VBox>
