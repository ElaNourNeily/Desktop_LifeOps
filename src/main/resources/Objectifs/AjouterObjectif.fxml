<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="580.0" prefWidth="440.0" spacing="13.0"
      style="-fx-background-color: #121417;"
      stylesheets="@style.css"
      xmlns="http://javafx.com/javafx/19"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controllers.AjouterObjectifController">
    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
    </padding>

    <Label styleClass="title-label" text="Créer un Objectif" />

    <!-- Titre -->
    <VBox spacing="4.0">
        <Label styleClass="form-label" text="Titre *" />
        <TextField fx:id="txtTitre" promptText="Ex: Apprendre JavaFX"
                   styleClass="form-field" maxWidth="Infinity" />
        <Label fx:id="errTitre" style="-fx-text-fill: #ff477e; -fx-font-size: 11px;" text="" visible="false" />
    </VBox>

    <!-- Catégorie -->
    <VBox spacing="4.0">
        <Label styleClass="form-label" text="Catégorie *" />
        <ComboBox fx:id="comboCategorie" maxWidth="Infinity"
                  promptText="Choisir une catégorie..."
                  styleClass="combo-form" />
        <Label fx:id="errCategorie" style="-fx-text-fill: #ff477e; -fx-font-size: 11px;" text="" visible="false" />
    </VBox>

    <!-- Description -->
    <VBox spacing="4.0">
        <Label styleClass="form-label" text="Description (Optionnelle)" />
        <TextArea fx:id="txtDescription" prefRowCount="3"
                  promptText="Décrivez votre objectif..."
                  style="-fx-control-inner-background: #2a2d32; -fx-text-fill: white;
                         -fx-prompt-text-fill: #6a6d71; -fx-border-color: #3a3d42;
                         -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8;
                         -fx-font-size: 13px;" />
    </VBox>

    <!-- Dates -->
    <HBox spacing="15.0">
        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
            <Label styleClass="form-label" text="Date de début *" />
            <DatePicker fx:id="dateDebut" maxWidth="Infinity" styleClass="date-form" />
            <Label fx:id="errDateDebut" style="-fx-text-fill: #ff477e; -fx-font-size: 11px;" text="" visible="false" />
        </VBox>
        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
            <Label styleClass="form-label" text="Date de fin *" />
            <DatePicker fx:id="dateFin" maxWidth="Infinity" styleClass="date-form" />
            <Label fx:id="errDateFin" style="-fx-text-fill: #ff477e; -fx-font-size: 11px;" text="" visible="false" />
        </VBox>
    </HBox>

    <!-- Statut -->
    <VBox spacing="4.0">
        <Label styleClass="form-label" text="Statut" />
        <ComboBox fx:id="comboStatut" maxWidth="Infinity"
                  promptText="Choisir un statut..."
                  styleClass="combo-form" />
    </VBox>

    <!-- Progression -->
    <VBox spacing="4.0">
        <Label styleClass="form-label" text="Progression (%)" />
        <Slider fx:id="sliderProgression" max="100.0" min="0.0"
                showTickLabels="true" showTickMarks="true"
                majorTickUnit="25.0" blockIncrement="5.0" />
        <Label fx:id="labelProgression"
               style="-fx-text-fill: #a78bfa; -fx-font-weight: bold;" text="0%" />
    </VBox>

    <Button fx:id="btnEnregistrer" maxWidth="Infinity"
            onAction="#handleEnregistrer"
            styleClass="btn-primary" text="Enregistrer" />

</VBox>
