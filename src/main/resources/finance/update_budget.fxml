<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="0"
      style="-fx-background-color: #17191F;"
      stylesheets="@../Task/board_style.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.UpdateBudgetController">

   <!-- Header -->
   <HBox alignment="CENTER_LEFT" style="-fx-padding: 32 40 20 40;">
      <VBox spacing="4" HBox.hgrow="ALWAYS">
         <Label style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="✏ Modifier le Budget" />
         <Label fx:id="budgetIdLabel" style="-fx-text-fill: #8a8d91; -fx-font-size: 13px;" text="" />
      </VBox>
   </HBox>

   <!-- Form card -->
   <VBox spacing="20.0" style="-fx-padding: 0 40 40 40;">
      <children>
         <VBox spacing="20.0"
               style="-fx-background-color: #17191F; -fx-background-radius: 20;
                      -fx-border-color: #2a2d32; -fx-border-width: 1; -fx-border-radius: 20; -fx-padding: 28;">
            <children>
               <HBox spacing="16.0">
                  <children>
                     <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                        <children>
                           <Label styleClass="field-label" text="Revenu mensuel" />
                           <TextField fx:id="revenuMensuelField" styleClass="form-field" />
                        </children>
                     </VBox>
                     <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                        <children>
                           <Label styleClass="field-label" text="Plafond de dépenses" />
                           <TextField fx:id="plafondField" styleClass="form-field" />
                        </children>
                     </VBox>
                  </children>
               </HBox>
               <HBox spacing="16.0">
                  <children>
                     <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                        <children>
                           <Label styleClass="field-label" text="Mois (MM-YYYY)" />
                           <TextField fx:id="moisField" styleClass="form-field" />
                        </children>
                     </VBox>
                     <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                        <children>
                           <Label styleClass="field-label" text="Économies" />
                           <TextField fx:id="economiesField" styleClass="form-field" />
                        </children>
                     </VBox>
                  </children>
               </HBox>
               <Label fx:id="messageLabel" style="-fx-text-fill: #f87171; -fx-font-size: 13px;" text="" />
               <HBox spacing="12.0">
                  <children>
                     <Button mnemonicParsing="false" onAction="#saveBudget"
                             styleClass="btn-primary" text="Enregistrer" />
                     <Button mnemonicParsing="false" onAction="#cancel"
                             styleClass="action-button" text="← Retour" />
                  </children>
               </HBox>
            </children>
         </VBox>
      </children>
   </VBox>

</VBox>
