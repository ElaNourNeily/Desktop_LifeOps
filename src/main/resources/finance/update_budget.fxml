<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="620.0" prefWidth="960.0" styleClass="root-pane" stylesheets="@../styleRead.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.UpdateBudgetController">
   <children>
      <VBox prefHeight="620.0" prefWidth="960.0" styleClass="main-content">
         <children>
            <VBox spacing="18.0">
               <padding><Insets bottom="30.0" left="40.0" right="40.0" top="40.0" /></padding>
               <children>
                  <Label styleClass="page-title" text="Modifier Budget" />
                  <Label fx:id="budgetIdLabel" styleClass="page-subtitle" text="Budget" />
                  <VBox spacing="18.0" styleClass="finance-form-panel">
                     <padding><Insets bottom="24.0" left="24.0" right="24.0" top="24.0" /></padding>
                     <children>
                        <HBox spacing="12.0">
                           <children>
                              <VBox spacing="8.0">
                                 <children>
                                    <Label styleClass="field-label" text="Revenu mensuel" />
                                    <TextField fx:id="revenuMensuelField" styleClass="form-field" />
                                 </children>
                              </VBox>
                              <VBox spacing="8.0">
                                 <children>
                                    <Label styleClass="field-label" text="Plafond" />
                                    <TextField fx:id="plafondField" styleClass="form-field" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                        <VBox spacing="8.0">
                           <children>
                              <Label styleClass="field-label" text="Mois (MM-YYYY)" />
                              <TextField fx:id="moisField" styleClass="form-field" />
                           </children>
                        </VBox>
                        <VBox spacing="8.0">
                           <children>
                              <Label styleClass="field-label" text="Economies" />
                              <TextField fx:id="economiesField" styleClass="form-field" />
                           </children>
                        </VBox>
                        <Label fx:id="messageLabel" styleClass="page-subtitle" text="" />
                        <HBox spacing="12.0">
                           <children>
                              <Button mnemonicParsing="false" onAction="#saveBudget" styleClass="submit-button" text="Enregistrer" />
                              <Button mnemonicParsing="false" onAction="#cancel" styleClass="action-button" text="Retour" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
