<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="0"
      style="-fx-background-color: #17191F;"
      stylesheets="@../Task/board_style.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.DeleteDepenseController">

   <!-- Header -->
   <HBox alignment="CENTER_LEFT" style="-fx-padding: 32 40 20 40;">
      <VBox spacing="4" HBox.hgrow="ALWAYS">
         <Label style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="🗑 Supprimer la Dépense" />
         <Label style="-fx-text-fill: #8a8d91; -fx-font-size: 13px;" text="Cette action est irréversible" />
      </VBox>
   </HBox>

   <!-- Confirmation card -->
   <VBox spacing="20.0" style="-fx-padding: 0 40 40 40;">
      <children>
         <VBox spacing="20.0"
               style="-fx-background-color: rgba(239,68,68,0.06); -fx-background-radius: 20;
                      -fx-border-color: rgba(239,68,68,0.25); -fx-border-width: 1; -fx-border-radius: 20; -fx-padding: 28;">
            <children>
               <Label fx:id="depenseInfoLabel"
                      style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="" />
               <Label style="-fx-text-fill: #f87171; -fx-font-size: 13px;"
                      text="⚠ Cette dépense sera définitivement supprimée."
                      wrapText="true" />
               <Label fx:id="messageLabel" style="-fx-text-fill: #f87171; -fx-font-size: 13px;" text="" />
               <HBox spacing="12.0">
                  <children>
                     <Button mnemonicParsing="false" onAction="#deleteDepense"
                             style="-fx-background-color: rgba(239,68,68,0.15); -fx-text-fill: #f87171;
                                    -fx-border-color: rgba(239,68,68,0.4); -fx-border-width: 1; -fx-border-radius: 10;
                                    -fx-background-radius: 10; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 9 18;"
                             text="Confirmer la suppression" />
                     <Button mnemonicParsing="false" onAction="#cancel"
                             styleClass="action-button" text="← Annuler" />
                  </children>
               </HBox>
            </children>
         </VBox>
      </children>
   </VBox>

</VBox>
