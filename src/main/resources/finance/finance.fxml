<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="0"
      style="-fx-background-color: #17191F;"
      stylesheets="@../Task/board_style.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controller.FinanceController">

   <!-- ── Page header ─────────────────────────── -->
   <HBox alignment="CENTER_LEFT" style="-fx-padding: 32 40 20 40;">
      <VBox spacing="4" HBox.hgrow="ALWAYS">
         <Label style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="💰 Finance" />
         <Label style="-fx-text-fill: #8a8d91; -fx-font-size: 13px;" text="Gérez vos budgets et dépenses personnelles" />
      </VBox>
      <Button mnemonicParsing="false" onAction="#initialize"
              styleClass="action-button" text="↻ Actualiser" />
   </HBox>

   <!-- ── Quick actions + status ─────────────────── -->
   <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-padding: 0 40 16 40;">
      <Button mnemonicParsing="false" onAction="#openAddBudget"
              styleClass="btn-primary" text="+ Nouveau budget"
              style="-fx-padding: 9 18;" />
      <Button mnemonicParsing="false" onAction="#openAddDepense"
              style="-fx-background-color: rgba(139,92,246,0.15); -fx-text-fill: #a78bfa;
                     -fx-border-color: rgba(139,92,246,0.3); -fx-border-radius: 10; -fx-background-radius: 10;
                     -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 9 18; -fx-font-weight: bold;"
              text="+ Nouvelle dépense" />
      <Region HBox.hgrow="ALWAYS" />
      <Label fx:id="financeMessageLabel"
             style="-fx-text-fill: #6a6d71; -fx-font-size: 12px;" text="" />
   </HBox>

   <!-- ── Reminders banner ─────────────────────── -->
   <VBox fx:id="remindersBanner" visible="false" managed="false" spacing="10.0"
         style="-fx-background-color: rgba(239,68,68,0.10); -fx-background-radius: 12;
                -fx-border-color: rgba(239,68,68,0.35); -fx-border-radius: 12; -fx-padding: 16;">
      <VBox.margin><Insets left="40.0" right="40.0" bottom="12.0" /></VBox.margin>
      <children>
         <HBox alignment="CENTER_LEFT" spacing="12.0">
            <children>
               <Label fx:id="remindersKickerLabel"
                      style="-fx-background-color: rgba(239,68,68,0.85); -fx-background-radius: 999;
                             -fx-padding: 4 10; -fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: bold;"
                      text="ALERTE 24H" />
               <Region HBox.hgrow="ALWAYS" />
               <Button mnemonicParsing="false" onAction="#markAllRemindersRead"
                       styleClass="action-button" text="Marquer lu" />
               <Button mnemonicParsing="false" onAction="#viewRemindersList"
                       styleClass="btn-primary" text="Voir la liste" />
            </children>
         </HBox>
         <Label fx:id="remindersTitleLabel"
                style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" text="" />
         <Label fx:id="remindersDetailLabel"
                style="-fx-text-fill: rgba(255,255,255,0.82); -fx-font-size: 13px;" text="" wrapText="true" />
         <Label fx:id="remindersMetaLabel"
                style="-fx-text-fill: rgba(255,255,255,0.55); -fx-font-size: 12px;" text="" />
      </children>
   </VBox>

   <!-- ── Scrollable content ───────────────────── -->
   <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
               style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
      <content>
         <VBox spacing="24.0" style="-fx-padding: 0 40 40 40;">
            <children>

               <!-- Hero card -->
               <VBox spacing="14.0"
                     style="-fx-background-color: linear-gradient(to right, rgba(28,31,45,0.96), rgba(97,61,164,0.78));
                            -fx-background-radius: 24; -fx-padding: 28;
                            -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 24;">
                  <children>
                     <Label style="-fx-text-fill: #d8b4fe; -fx-font-size: 11px; -fx-font-weight: bold;"
                            text="FINANCE WORKSPACE" />
                     <HBox alignment="CENTER_LEFT" spacing="20.0">
                        <children>
                           <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                              <children>
                                 <Label style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;"
                                        text="Vos Budgets et Dépenses" />
                                 <Label style="-fx-text-fill: rgba(255,255,255,0.78); -fx-font-size: 13px;"
                                        text="Créez un budget, rattachez-y des dépenses pour mieux organiser votre vie financière."
                                        wrapText="true" />
                              </children>
                           </VBox>
                           <VBox spacing="8.0"
                                 style="-fx-background-color: rgba(12,14,20,0.35); -fx-background-radius: 18; -fx-padding: 12 20;">
                              <children>
                                 <Label style="-fx-text-fill: #c4b5fd; -fx-font-size: 11px;" text="Vue active" />
                                 <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Finance" />
                              </children>
                           </VBox>
                        </children>
                     </HBox>
                  </children>
               </VBox>

               <!-- Insights / Suggestions card -->
               <VBox spacing="16.0"
                     style="-fx-background-color: #17191F; -fx-background-radius: 20;
                            -fx-border-color: #2a2d32; -fx-border-width: 1; -fx-border-radius: 20; -fx-padding: 24;">
                  <children>
                     <HBox alignment="CENTER_LEFT">
                        <children>
                           <VBox spacing="3" HBox.hgrow="ALWAYS">
                              <Label style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"
                                     text="💡 Suggestions IA" />
                              <Label fx:id="insightsSubtitleLabel"
                                     style="-fx-text-fill: #8a8d91; -fx-font-size: 12px;" text="" />
                           </VBox>
                           <Button mnemonicParsing="false" onAction="#dismissInsights"
                                   styleClass="action-button" text="Masquer" />
                        </children>
                     </HBox>
                     <VBox fx:id="recurringBox" spacing="8.0">
                        <children>
                           <Label style="-fx-text-fill: #a78bfa; -fx-font-size: 11px; -fx-font-weight: bold;"
                                  text="DÉPENSES RÉCURRENTES DÉTECTÉES" />
                           <Label fx:id="recurringSummaryLabel"
                                  style="-fx-text-fill: #8a8d91; -fx-font-size: 13px;" text="" wrapText="true" />
                        </children>
                     </VBox>
                     <VBox fx:id="priorityBox" spacing="8.0">
                        <children>
                           <Label style="-fx-text-fill: #a78bfa; -fx-font-size: 11px; -fx-font-weight: bold;"
                                  text="PRIORITÉ PROPOSÉE (HIGH / MED / LOW)" />
                           <Label fx:id="prioritySummaryLabel"
                                  style="-fx-text-fill: #8a8d91; -fx-font-size: 13px;" text="" wrapText="true" />
                        </children>
                     </VBox>
                  </children>
               </VBox>

               <!-- Search & sort bar -->
               <VBox spacing="14.0"
                     style="-fx-background-color: #17191F; -fx-background-radius: 16;
                            -fx-border-color: #2a2d32; -fx-border-width: 1; -fx-border-radius: 16; -fx-padding: 20;">
                  <children>
                     <Label style="-fx-text-fill: #c0c3c8; -fx-font-size: 11px; -fx-font-weight: bold;"
                            text="RECHERCHE ET TRI" />
                     <HBox spacing="16.0">
                        <children>
                           <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                              <children>
                                 <Label style="-fx-text-fill: #6a6d71; -fx-font-size: 11px;" text="Budget (mois: 04-2026, revenu...)" />
                                 <HBox spacing="8.0">
                                    <children>
                                       <TextField fx:id="budgetSearchField" promptText="🔍 Rechercher budget..."
                                                  styleClass="search-field" HBox.hgrow="ALWAYS" />
                                       <ComboBox fx:id="sortBudgetComboBox" prefWidth="180.0"
                                                 style="-fx-background-color: #1c1e22; -fx-text-fill: white;
                                                        -fx-background-radius: 10; -fx-border-color: #2a2d32; -fx-border-radius: 10;" />
                                    </children>
                                 </HBox>
                              </children>
                           </VBox>
                           <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                              <children>
                                 <Label style="-fx-text-fill: #6a6d71; -fx-font-size: 11px;" text="Dépense (titre, catégorie, paiement...)" />
                                 <HBox spacing="8.0">
                                    <children>
                                       <TextField fx:id="depenseSearchField" promptText="🔍 Rechercher dépense..."
                                                  styleClass="search-field" HBox.hgrow="ALWAYS" />
                                       <ComboBox fx:id="sortDepenseComboBox" prefWidth="180.0"
                                                 style="-fx-background-color: #1c1e22; -fx-text-fill: white;
                                                        -fx-background-radius: 10; -fx-border-color: #2a2d32; -fx-border-radius: 10;" />
                                    </children>
                                 </HBox>
                              </children>
                           </VBox>
                        </children>
                     </HBox>
                  </children>
               </VBox>

               <!-- Budget cards container (populated by controller) -->
               <VBox fx:id="budgetCardsContainer" spacing="16.0" />

            </children>
         </VBox>
      </content>
   </ScrollPane>

</VBox>
