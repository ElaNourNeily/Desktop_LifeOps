<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="420.0" prefWidth="760.0" styleClass="root-pane" stylesheets="@../styleRead.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.DeleteBudgetController">
   <children>
      <VBox prefHeight="420.0" prefWidth="760.0" styleClass="main-content">
         <children>
            <VBox spacing="18.0">
               <padding><Insets bottom="30.0" left="40.0" right="40.0" top="40.0" /></padding>
               <children>
                  <Label styleClass="page-title" text="Supprimer Budget" />
                  <VBox spacing="18.0" styleClass="finance-form-panel">
                     <padding><Insets bottom="24.0" left="24.0" right="24.0" top="24.0" /></padding>
                     <children>
                        <Label fx:id="budgetInfoLabel" styleClass="finance-panel-title" text="Supprimer le budget ?" />
                        <Label styleClass="page-subtitle" text="Les depenses liees a ce budget seront supprimees aussi." wrapText="true" />
                        <Label fx:id="messageLabel" styleClass="page-subtitle" text="" />
                        <HBox spacing="12.0">
                           <children>
                              <Button mnemonicParsing="false" onAction="#deleteBudget" styleClass="finance-delete-button" text="Confirmer suppression" />
                              <Button mnemonicParsing="false" onAction="#cancel" styleClass="action-button" text="Annuler" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
