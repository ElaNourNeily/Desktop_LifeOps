<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="900.0" prefWidth="1200.0" styleClass="main-content" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.PlanningManagementController">
   <children>
      <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <content>
            <VBox spacing="30.0" styleClass="main-content">
               <padding>
                  <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
               </padding>
               <children>
                  <!-- WORKFLOW HEADER -->
                  <VBox spacing="15.0">
                     <children>
                        <HBox alignment="BOTTOM_LEFT" spacing="20.0">
                           <children>
                              <VBox HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label styleClass="badge-ai" style="-fx-background-color: rgba(139, 92, 246, 0.1); -fx-text-fill: #8b5cf6;" text="FLUX DE TRAVAIL" />
                                    <Label fx:id="lblTitle" styleClass="page-title" text="Gestion du Temps">
                                       <font>
                                          <Font name="System Bold" size="32.0" />
                                       </font>
                                    </Label>
                                 </children>
                              </VBox>
                              <Button mnemonicParsing="false" onAction="#handleAdd" prefHeight="45.0" styleClass="submit-button" text="+ Créer un Planning">
                                 <padding>
                                    <Insets left="20.0" right="20.0" />
                                 </padding>
                              </Button>
                           </children>
                        </HBox>
                        
                        <!-- Tab-like Toggles -->
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                           <children>
                              <HBox alignment="CENTER" onMouseClicked="#handleSwitchToCalendar" spacing="8.0" style="-fx-cursor: hand;">
                                 <children>
                                    <Label onMouseClicked="#handleSwitchToCalendar" text="📅" />
                                    <Label onMouseClicked="#handleSwitchToCalendar" style="-fx-text-fill: #71717a; -fx-font-weight: bold;" text="Calendrier" />
                                 </children>
                              </HBox>
                              <HBox alignment="CENTER" spacing="8.0" style="-fx-cursor: hand; -fx-border-color: transparent transparent #8b5cf6 transparent; -fx-border-width: 0 0 2 0; -fx-padding: 0 0 5 0;">
                                 <children>
                                    <Label text="⚙" />
                                    <Label text="Liste des Plannings" style="-fx-text-fill: #8b5cf6; -fx-font-weight: bold;" />
                                 </children>
                              </HBox>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
      
                  <!-- PLANNING LIST BODY -->
                  <VBox styleClass="card-dark">
                     <children>
                        <!-- List Headers -->
                        <HBox alignment="CENTER_LEFT" prefHeight="50.0" spacing="10.0" style="-fx-padding: 0 30; -fx-background-color: rgba(255,255,255,0.02);">
                           <children>
                              <Label prefWidth="150.0" text="JOURNÉE" styleClass="indicator-label" />
                              <Label prefWidth="200.0" text="AMPLITUDE HORAIRE" styleClass="indicator-label" />
                              <Label prefWidth="200.0" text="APERÇU ACTIVITÉS" styleClass="indicator-label" />
                              <Label prefWidth="120.0" text="STATUT" styleClass="indicator-label" />
                              <Region HBox.hgrow="ALWAYS" />
                              <Label text="ACTIONS" styleClass="indicator-label" />
                           </children>
                        </HBox>
                        <VBox fx:id="vboxPlanningList" spacing="15.0" style="-fx-padding: 20;">
                            <!-- Dynamic content -->
                        </VBox>
                     </children>
                  </VBox>
      
                  <!-- STATISTICS SECTION -->
                  <VBox spacing="20.0">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                           <children>
                              <Label style="-fx-background-color: rgba(16, 185, 129, 0.1); -fx-background-radius: 8; -fx-padding: 8;" text="📊" />
                              <Label text="STATISTIQUES D'ANALYSE" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14;" />
                           </children>
                        </HBox>
      
                        <HBox spacing="25.0">
                           <children>
                              <VBox spacing="15.0" styleClass="card-dark" style="-fx-padding: 25;" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label text="TEMPS TRAVAILLÉ PAR SEMAINE" styleClass="indicator-label" />
                                    <BarChart fx:id="barChartWeeklyWork" legendVisible="false" prefHeight="200.0">
                                      <xAxis><CategoryAxis side="BOTTOM" tickLabelFill="#71717a"/></xAxis>
                                      <yAxis><NumberAxis side="LEFT" tickLabelFill="#71717a"/></yAxis>
                                    </BarChart>
                                 </children>
                              </VBox>
                              <VBox spacing="15.0" styleClass="card-dark" style="-fx-padding: 25;" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label text="RÉPARTITION PAR PRIORITÉ" styleClass="indicator-label" />
                                    <PieChart fx:id="pieChartPriority" legendVisible="false" prefHeight="200.0" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
      
                        <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="card-dark" style="-fx-padding: 20;">
                           <children>
                              <Label style="-fx-background-color: rgba(139, 92, 246, 0.1); -fx-background-radius: 12; -fx-padding: 12;" text="🎯" />
                              <VBox spacing="5.0">
                                 <children>
                                    <Label text="EFFICACITÉ GLOBALE" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 11;" />
                                    <Label text="Votre taux de complétion moyen sur l'ensemble de vos activités." style="-fx-text-fill: #71717a; -fx-font-size: 10;" />
                                 </children>
                              </VBox>
                              <Region HBox.hgrow="ALWAYS" />
                              <VBox alignment="CENTER_RIGHT">
                                 <children>
                                    <Label fx:id="lblEfficiency" text="100.0%" style="-fx-text-fill: #8b5cf6; -fx-font-weight: bold; -fx-font-size: 32;" />
                                    <AnchorPane prefHeight="4.0" prefWidth="120.0" style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 10;">
                                       <children>
                                          <AnchorPane fx:id="efficiencyProgress" prefHeight="4.0" prefWidth="120.0" styleClass="gradient-primary" style="-fx-background-radius: 10;" />
                                       </children>
                                    </AnchorPane>
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </VBox>
         </content>
      </ScrollPane>
   </children>
</AnchorPane>
