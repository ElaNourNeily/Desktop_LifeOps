<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="718.0" prefWidth="1053.0" style="-fx-background-color: #0f172a;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.ReadSanteController">
   <children>
      <!-- Barre Latérale avec accent Mauve -->
      <VBox prefHeight="718.0" prefWidth="181.0" style="-fx-background-color: #020617;">
         <children>
            <Label text="LifeOps" textFill="WHITE">
               <font><Font name="System Bold" size="21.0" /></font>
               <VBox.margin><Insets left="50.0" top="30.0" /></VBox.margin>
            </Label>
            <Pane prefHeight="77.0" prefWidth="181.0" />
            <Button mnemonicParsing="false" prefHeight="45.0" prefWidth="181.0" style="-fx-background-color: transparent;" text="Tableau de bord" textFill="#94a3b8">
               <font><Font size="14.0" /></font>
            </Button>
            <Button mnemonicParsing="false" prefHeight="45.0" prefWidth="181.0" style="-fx-background-color: transparent;" text="Tâches" textFill="#94a3b8">
               <font><Font size="14.0" /></font>
            </Button>
            <Button mnemonicParsing="false" prefHeight="45.0" prefWidth="181.0" style="-fx-background-color: #1e293b; -fx-text-fill: #a78bfa;" text="Santé">
               <font><Font name="System Bold" size="14.0" /></font>
            </Button>
         </children>
      </VBox>

      <!-- Contenu Thème Mauve -->
      <VBox layoutX="181.0" prefHeight="718.0" prefWidth="872.0" spacing="20.0">
         <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>
         <children>
            <HBox alignment="CENTER_LEFT" spacing="20.0">
               <children>
                  <VBox>
                     <children>
                        <Label text="Gestion de Santé" textFill="WHITE">
                           <font><Font name="System Bold" size="28.0" /></font>
                        </Label>
                        <Label text="Votre assistant bien-être intelligent" textFill="#c4b5fd" />
                     </children>
                  </VBox>
                  <HBox spacing="10.0">
                     <children>
                        <Button onAction="#openDashboard" style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-background-radius: 5px; -fx-cursor: hand;" text="📈 Dashboard IA" />
                        <Button onAction="#openDrugSearch" style="-fx-background-color: #334155; -fx-text-fill: white; -fx-background-radius: 5px; -fx-cursor: hand;" text="💊 Médicaments" />
                        <Button onAction="#openHealthArticles" style="-fx-background-color: #a78bfa; -fx-text-fill: white; -fx-background-radius: 5px; -fx-cursor: hand;" text="📚 Articles Santé" />
                     </children>
                  </HBox>
                  <VBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                     <children>
                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                           <children>
                              <Button onAction="#openCreate" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5px; -fx-padding: 8 15;" text="+ Nouveau Relevé" />
                              <Button onAction="#openCreateBilan" style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5px; -fx-padding: 8 15;" text="🪄 Bilan IA" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </HBox>

            <HBox spacing="10.0">
               <children>
                  <Button fx:id="btnTabSuivi" onAction="#showSuivis" prefWidth="120.0" style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-background-radius: 5;" text="Mes Suivis" />
                  <Button fx:id="btnTabBilan" onAction="#showBilans" prefWidth="120.0" style="-fx-background-color: #1e293b; -fx-text-fill: #c4b5fd; -fx-background-radius: 5;" text="Mes Bilans" />
               </children>
            </HBox>

            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
               <content>
                  <VBox spacing="15.0">
                     <children>
                        <HBox fx:id="suiviFilterBar" alignment="CENTER_LEFT" spacing="15.0">
                           <children>
                              <Label text="TRIER PAR :" textFill="#94a3b8">
                                 <font><Font name="System Bold" size="11.0" /></font>
                              </Label>
                              <Button fx:id="btnFilterJour" onAction="#filterByJour" style="-fx-background-color: transparent; -fx-text-fill: #c4b5fd; -fx-font-weight: bold;" text="AUJOURD'HUI" />
                              <Button fx:id="btnFilterMois" onAction="#filterByMois" style="-fx-background-color: transparent; -fx-text-fill: #94a3b8;" text="CE MOIS" />
                              <Button fx:id="btnFilterAnnee" onAction="#filterByAnnee" style="-fx-background-color: transparent; -fx-text-fill: #94a3b8;" text="CETTE ANNÉE" />
                              <Button onAction="#resetFilters" style="-fx-background-color: transparent; -fx-text-fill: #94a3b8;" text="TOUT VOIR" />
                           </children>
                        </HBox>
                        <HBox fx:id="bilanFilterBar" alignment="CENTER_LEFT" managed="false" spacing="10.0" visible="false">
                           <children>
                              <Button fx:id="btnToggleBurnout" onAction="#toggleBurnoutFilter" style="-fx-background-color: #ef444422; -fx-text-fill: #ef4444; -fx-border-color: #ef4444; -fx-border-radius: 5;" text="⚠️ RISQUES DE BURNOUT" />
                           </children>
                        </HBox>
                        <VBox fx:id="santeListContainer" spacing="12.0" />
                        <VBox fx:id="bilanListContainer" managed="false" spacing="12.0" visible="false" />
                     </children>
                  </VBox>
               </content>
            </ScrollPane>
         </children>
      </VBox>
   </children>
</AnchorPane>
