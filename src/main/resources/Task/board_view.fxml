<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0"
            style="-fx-background-color: #121417;"
            stylesheets="@board_style.css"
            xmlns="http://javafx.com/javafx/19"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.task.BoardViewController">

    <children>
        <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>

                <!-- ── BOARD HEADER ──────────────────────────── -->
                <VBox style="-fx-background-color: #17191F; -fx-border-color: #2a2d32; -fx-border-width: 0 0 1 0; -fx-padding: 18 30 18 30;">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="16.0">
                            <children>
                                <Button fx:id="btnBack" onAction="#handleBack"
                                        mnemonicParsing="false"
                                        styleClass="action-button"
                                        text="← Retour" />
                                <VBox spacing="4.0">
                                    <children>
                                        <Label fx:id="lblBoardTitle" styleClass="title-label"
                                               text="Refonte Site Web" />
                                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                                            <children>
                                                <Label fx:id="lblBoardType" styleClass="board-type-tag"
                                                       text="TEAM BOARD" />
                                                <Label styleClass="subtitle-label" text="•" />
                                                <Label fx:id="lblBoardSubtitle" styleClass="subtitle-label"
                                                       text="Sprint 4 (14 jours)" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                    <children>
                                        <!-- Member avatars -->
                                        <HBox fx:id="membersContainer" alignment="CENTER_LEFT" spacing="-8.0">
                                            <children>
                                                <Label style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-background-radius: 50%; -fx-min-width: 30; -fx-min-height: 30; -fx-alignment: center; -fx-border-color: #121417; -fx-border-width: 2; -fx-border-radius: 50%; -fx-font-size: 11px; -fx-font-weight: bold;" text="AS" />
                                                <Label style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-background-radius: 50%; -fx-min-width: 30; -fx-min-height: 30; -fx-alignment: center; -fx-border-color: #121417; -fx-border-width: 2; -fx-border-radius: 50%; -fx-font-size: 11px; -fx-font-weight: bold;" text="MK" />
                                                <Button fx:id="btnInvite" onAction="#handleInviteMember"
                                                        mnemonicParsing="false"
                                                        style="-fx-background-color: #2a2d32; -fx-text-fill: #a78bfa; -fx-background-radius: 50%; -fx-min-width: 30; -fx-min-height: 30; -fx-padding: 0; -fx-border-color: #121417; -fx-border-width: 2; -fx-border-radius: 50%; -fx-font-weight: bold; -fx-cursor: hand;"
                                                        text="+" />
                                            </children>
                                        </HBox>
                                        <Button fx:id="btnAISuggest" onAction="#handleAISuggestAssignment"
                                                mnemonicParsing="false"
                                                styleClass="btn-primary"
                                                text="🤖 AI Suggest" />
                                        <Button fx:id="btnDeleteBoard" onAction="#handleDeleteBoard"
                                                mnemonicParsing="false"
                                                style="-fx-background-color: rgba(239,68,68,0.12); -fx-text-fill: #f87171; -fx-border-color: rgba(239,68,68,0.3); -fx-border-width: 1; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8 14;"
                                                text="Supprimer" />
                                    </children>
                                </HBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <!-- ── KANBAN BOARD ──────────────────────────── -->
                <ScrollPane fitToHeight="true" VBox.vgrow="ALWAYS"
                            style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                    <content>
                        <HBox spacing="18.0" style="-fx-padding: 24 30 30 30;">
                            <children>

                                <!-- TO DO Column -->
                                <VBox prefWidth="270.0" spacing="12.0" styleClass="kanban-column">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="column-header"
                                              style="-fx-border-color: #3b82f6; -fx-border-width: 0 0 2 0; -fx-padding: 0 0 12 0;">
                                            <children>
                                                <Label style="-fx-background-color: rgba(59,130,246,0.15); -fx-text-fill: #60a5fa; -fx-background-radius: 6; -fx-padding: 3 8; -fx-font-size: 10px; -fx-font-weight: bold;" text="À FAIRE" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Label styleClass="task-count" text="0" />
                                            </children>
                                        </HBox>
                                        <VBox fx:id="colToDo" spacing="10.0" VBox.vgrow="ALWAYS" />
                                        <Button onAction="#handleAddTask" maxWidth="Infinity"
                                                mnemonicParsing="false"
                                                style="-fx-background-color: transparent; -fx-text-fill: #6a6d71; -fx-alignment: center-left; -fx-cursor: hand; -fx-border-color: #2a2d32; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 7 12;"
                                                text="＋  Ajouter une tâche" />
                                    </children>
                                </VBox>

                                <!-- IN PROGRESS Column -->
                                <VBox prefWidth="270.0" spacing="12.0" styleClass="kanban-column">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="column-header"
                                              style="-fx-border-color: #f59e0b; -fx-border-width: 0 0 2 0; -fx-padding: 0 0 12 0;">
                                            <children>
                                                <Label style="-fx-background-color: rgba(245,158,11,0.15); -fx-text-fill: #fbbf24; -fx-background-radius: 6; -fx-padding: 3 8; -fx-font-size: 10px; -fx-font-weight: bold;" text="EN COURS" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Label styleClass="task-count" text="0" />
                                            </children>
                                        </HBox>
                                        <VBox fx:id="colInProgress" spacing="10.0" VBox.vgrow="ALWAYS" />
                                        <Button onAction="#handleAddTask" maxWidth="Infinity"
                                                mnemonicParsing="false"
                                                style="-fx-background-color: transparent; -fx-text-fill: #6a6d71; -fx-alignment: center-left; -fx-cursor: hand; -fx-border-color: #2a2d32; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 7 12;"
                                                text="＋  Ajouter une tâche" />
                                    </children>
                                </VBox>

                                <!-- REVIEW Column -->
                                <VBox prefWidth="270.0" spacing="12.0" styleClass="kanban-column">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="column-header"
                                              style="-fx-border-color: #8b5cf6; -fx-border-width: 0 0 2 0; -fx-padding: 0 0 12 0;">
                                            <children>
                                                <Label style="-fx-background-color: rgba(139,92,246,0.15); -fx-text-fill: #a78bfa; -fx-background-radius: 6; -fx-padding: 3 8; -fx-font-size: 10px; -fx-font-weight: bold;" text="RÉVISION" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Label styleClass="task-count" text="0" />
                                            </children>
                                        </HBox>
                                        <VBox fx:id="colReview" spacing="10.0" VBox.vgrow="ALWAYS" />
                                        <Button onAction="#handleAddTask" maxWidth="Infinity"
                                                mnemonicParsing="false"
                                                style="-fx-background-color: transparent; -fx-text-fill: #6a6d71; -fx-alignment: center-left; -fx-cursor: hand; -fx-border-color: #2a2d32; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 7 12;"
                                                text="＋  Ajouter une tâche" />
                                    </children>
                                </VBox>

                                <!-- DONE Column -->
                                <VBox prefWidth="270.0" spacing="12.0" styleClass="kanban-column">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="column-header"
                                              style="-fx-border-color: #10b981; -fx-border-width: 0 0 2 0; -fx-padding: 0 0 12 0;">
                                            <children>
                                                <Label style="-fx-background-color: rgba(16,185,129,0.15); -fx-text-fill: #34d399; -fx-background-radius: 6; -fx-padding: 3 8; -fx-font-size: 10px; -fx-font-weight: bold;" text="TERMINÉ" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Label styleClass="task-count" text="0" />
                                            </children>
                                        </HBox>
                                        <VBox fx:id="colDone" spacing="10.0" VBox.vgrow="ALWAYS" />
                                        <Button maxWidth="Infinity" mnemonicParsing="false"
                                                style="-fx-background-color: transparent; -fx-text-fill: #6a6d71; -fx-alignment: center-left; -fx-cursor: hand; -fx-border-color: #2a2d32; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 7 12;"
                                                text="＋  Ajouter une tâche" />
                                    </children>
                                </VBox>

                            </children>
                        </HBox>
                    </content>
                </ScrollPane>

            </children>
        </VBox>

        <!-- Task Details Side Panel -->
        <fx:include fx:id="taskDetailsPanel" source="task_details_panel.fxml"
                    AnchorPane.bottomAnchor="0.0" AnchorPane.rightAnchor="0.0"
                    AnchorPane.topAnchor="0.0" visible="false" />
    </children>
</AnchorPane>
