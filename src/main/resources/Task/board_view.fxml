<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #121417;" stylesheets="@board_style.css" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.BoardViewController">
   <children>
      <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <!-- Sub Header / Board Navigation -->
            <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-padding: 20 30;">
               <children>
                  <Button fx:id="btnBack" onAction="#handleBack" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-text-fill: #8a8d91;" text="← Retour" />
                  <VBox>
                     <children>
                        <Label fx:id="lblBoardTitle" styleClass="title-label" text="Refonte Site Web" />
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                           <children>
                              <Label fx:id="lblBoardType" styleClass="board-type-tag" text="TEAM BOARD" />
                              <Label styleClass="subtitle-label" text="•" />
                              <Label fx:id="lblBoardSubtitle" styleClass="subtitle-label" text="Sprint 4 (14 jours)" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <HBox alignment="CENTER_LEFT" spacing="15.0">
                     <children>
                        <HBox fx:id="membersContainer" alignment="CENTER_LEFT" spacing="-8.0">
                           <children>
                              <Label style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-background-radius: 50%; -fx-min-width: 28; -fx-min-height: 28; -fx-alignment: center; -fx-border-color: #121417; -fx-border-width: 2; -fx-border-radius: 50%;" text="AS" />
                              <Label style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-background-radius: 50%; -fx-min-width: 28; -fx-min-height: 28; -fx-alignment: center; -fx-border-color: #121417; -fx-border-width: 2; -fx-border-radius: 50%;" text="MK" />
                              <Button mnemonicParsing="false" style="-fx-background-color: #2a2d32; -fx-text-fill: #c0c3c8; -fx-background-radius: 50%; -fx-min-width: 28; -fx-min-height: 28; -fx-padding: 0; -fx-border-color: #121417; -fx-border-width: 2; -fx-border-radius: 50%;" text="+" />
                           </children>
                        </HBox>
                        <Button onAction="#handleDeleteBoard" mnemonicParsing="false" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6;" text="Supprimer le Board" />
                        <Button mnemonicParsing="false" styleClass="btn-primary" text="Convertir en Équipe" visible="false" />
                     </children>
                  </HBox>
               </children>
            </HBox>

            <!-- Kanban Board Area -->
            <ScrollPane fitToHeight="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
               <content>
                  <HBox spacing="20.0" style="-fx-padding: 10 30 30 30;">
                     <children>
                        <!-- To Do Column -->
                        <VBox prefWidth="280.0" spacing="15.0" styleClass="kanban-column">
                           <children>
                              <HBox alignment="CENTER_LEFT" styleClass="column-header">
                                 <children>
                                    <Label styleClass="column-title" text="À Faire" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label styleClass="task-count" text="3" />
                                 </children>
                              </HBox>
                              <VBox fx:id="colToDo" spacing="10.0" VBox.vgrow="ALWAYS" />
                              <Button onAction="#handleAddTask" maxWidth="Infinity" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-text-fill: #8a8d91; -fx-alignment: center-left;" text="+ Ajouter une tâche" />
                           </children>
                        </VBox>

                        <!-- In Progress Column -->
                        <VBox prefWidth="280.0" spacing="15.0" styleClass="kanban-column">
                           <children>
                              <HBox alignment="CENTER_LEFT" styleClass="column-header">
                                 <children>
                                    <Label styleClass="column-title" text="En Cours" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label styleClass="task-count" text="2" />
                                 </children>
                              </HBox>
                              <VBox fx:id="colInProgress" spacing="10.0" VBox.vgrow="ALWAYS" />
                              <Button onAction="#handleAddTask" maxWidth="Infinity" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-text-fill: #8a8d91; -fx-alignment: center-left;" text="+ Ajouter une tâche" />
                           </children>
                        </VBox>

                        <!-- Review Column -->
                        <VBox prefWidth="280.0" spacing="15.0" styleClass="kanban-column">
                           <children>
                              <HBox alignment="CENTER_LEFT" styleClass="column-header">
                                 <children>
                                    <Label styleClass="column-title" text="Révision" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label styleClass="task-count" text="1" />
                                 </children>
                              </HBox>
                              <VBox fx:id="colReview" spacing="10.0" VBox.vgrow="ALWAYS" />
                              <Button onAction="#handleAddTask" maxWidth="Infinity" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-text-fill: #8a8d91; -fx-alignment: center-left;" text="+ Ajouter une tâche" />
                           </children>
                        </VBox>

                        <!-- Done Column -->
                        <VBox prefWidth="280.0" spacing="15.0" styleClass="kanban-column">
                           <children>
                              <HBox alignment="CENTER_LEFT" styleClass="column-header">
                                 <children>
                                    <Label styleClass="column-title" text="Terminé" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label styleClass="task-count" text="12" />
                                 </children>
                              </HBox>
                              <VBox fx:id="colDone" spacing="10.0" VBox.vgrow="ALWAYS" />
                              <Button maxWidth="Infinity" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-text-fill: #8a8d91; -fx-alignment: center-left;" text="+ Ajouter une tâche" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>
               </content>
            </ScrollPane>
         </children>
      </VBox>
      
      <!-- Task Details Side Panel (Hidden by default, will be controlled by animation/visibility) -->
      <fx:include fx:id="taskDetailsPanel" source="task_details_panel.fxml" AnchorPane.bottomAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" visible="false" />
   </children>
</AnchorPane>
