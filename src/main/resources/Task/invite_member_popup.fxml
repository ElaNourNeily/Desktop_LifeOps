<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="18.0" prefWidth="420.0" prefHeight="500.0"
      styleClass="popup-card"
      stylesheets="@board_style.css"
      xmlns="http://javafx.com/javafx/19"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.InviteMemberController">

    <padding>
        <Insets bottom="28.0" left="28.0" right="28.0" top="28.0" />
    </padding>

    <children>

        <!-- Header -->
        <VBox spacing="4.0">
            <children>
                <Label styleClass="popup-title" text="Inviter des membres" />
                <Label styleClass="popup-subtitle"
                       text="Recherchez et ajoutez des membres à ce board." />
            </children>
        </VBox>

        <!-- Search -->
        <TextField fx:id="searchField"
                   promptText="🔍  Rechercher par nom ou email..."
                   styleClass="search-field" />

        <!-- Users list -->
        <ListView fx:id="usersList" VBox.vgrow="ALWAYS"
                  style="-fx-background-color: #17191F; -fx-border-color: #2a2d32; -fx-border-radius: 10; -fx-background-radius: 10;" />

        <!-- Status label -->
        <Label fx:id="lblStatus"
               style="-fx-font-size: 12px; -fx-font-weight: bold;"
               visible="false" wrapText="true" />

        <!-- Footer -->
        <HBox alignment="CENTER_RIGHT">
            <children>
                <Region HBox.hgrow="ALWAYS" />
                <Button mnemonicParsing="false" onAction="#handleClose"
                        style="-fx-background-color: transparent; -fx-text-fill: #8a8d91; -fx-cursor: hand; -fx-padding: 8 14; -fx-border-color: #2a2d32; -fx-border-width: 1; -fx-border-radius: 10; -fx-background-radius: 10;"
                        text="Fermer" />
            </children>
        </HBox>

    </children>
</VBox>
