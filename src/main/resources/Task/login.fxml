<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="600.0" prefWidth="500.0"
      style="-fx-background-color: #121417;"
      stylesheets="@board_style.css"
      xmlns="http://javafx.com/javafx/19"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.task.LoginController">

    <children>

        <!-- Login Card -->
        <VBox alignment="CENTER" spacing="24.0" maxWidth="380.0"
              styleClass="login-card">

            <!-- Logo / Brand -->
            <VBox alignment="CENTER" spacing="8.0">
                <children>
                    <Label style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: bold;"
                           text="⚡ LifeOps" />
                    <Label style="-fx-background-color: rgba(139,92,246,0.15); -fx-text-fill: #a78bfa; -fx-background-radius: 999; -fx-padding: 3 14; -fx-font-size: 11px; -fx-font-weight: bold;"
                           text="Task Management" />
                    <Label styleClass="subtitle-label"
                           text="Connectez-vous pour gérer vos tâches" />
                </children>
            </VBox>

            <!-- Form -->
            <VBox spacing="14.0" maxWidth="320.0">
                <children>
                    <VBox spacing="6.0">
                        <children>
                            <Label styleClass="form-label" text="EMAIL" />
                            <TextField fx:id="txtEmail" promptText="votre@email.com"
                                       styleClass="form-field" />
                        </children>
                    </VBox>
                    <VBox spacing="6.0">
                        <children>
                            <Label styleClass="form-label" text="MOT DE PASSE" />
                            <PasswordField fx:id="txtPassword" promptText="••••••••"
                                           styleClass="form-field" />
                        </children>
                    </VBox>
                    <Label fx:id="lblError"
                           style="-fx-text-fill: #f87171; -fx-font-size: 11px; -fx-background-color: rgba(239,68,68,0.1); -fx-background-radius: 6; -fx-padding: 6 10;"
                           visible="false" wrapText="true" />
                </children>
            </VBox>

            <!-- Submit -->
            <Button fx:id="btnLogin" onAction="#handleLogin"
                    prefWidth="320.0" styleClass="btn-primary"
                    text="Connexion" />

            <!-- Register link -->
            <HBox alignment="CENTER" spacing="8.0">
                <children>
                    <Label styleClass="subtitle-label" text="Nouveau ici ?" />
                    <Button mnemonicParsing="false"
                            style="-fx-background-color: transparent; -fx-text-fill: #a78bfa; -fx-padding: 0; -fx-cursor: hand;"
                            text="Créer un compte" />
                </children>
            </HBox>

        </VBox>

    </children>
</VBox>
