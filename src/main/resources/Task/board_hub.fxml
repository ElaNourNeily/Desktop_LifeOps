<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="700.0" prefWidth="940.0" spacing="0"
      style="-fx-background-color: #121417;"
      stylesheets="@board_style.css"
      xmlns="http://javafx.com/javafx/19"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.task.BoardHubController">

    <padding>
        <Insets bottom="30.0" left="36.0" right="36.0" top="32.0" />
    </padding>

    <children>

        <!-- ══════════════════════════════════════════════════
             SECTION 1 — HERO CARD
             Full-width gradient banner, stands alone
        ══════════════════════════════════════════════════ -->
        <VBox spacing="12.0" styleClass="task-hero-card">
            <children>
                <Label styleClass="task-hero-kicker" text="TASK WORKSPACE" />
                <HBox alignment="CENTER_LEFT" spacing="24.0">
                    <children>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="task-hero-title" text="Vos Tableaux" />
                                <Label styleClass="task-hero-subtitle"
                                       text="Gérez vos projets personnels et d'équipe depuis un seul endroit."
                                       wrapText="true" />
                            </children>
                        </VBox>
                        <!-- Stat chip — right side -->
                        <VBox spacing="4.0" styleClass="task-stat-highlight" minWidth="100.0">
                            <children>
                                <Label styleClass="task-stat-caption" text="Vue active" />
                                <Label styleClass="task-stat-value" text="Kanban" />
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>

        <!-- Gap between hero and toolbar -->
        <Region prefHeight="28.0" />

        <!-- ══════════════════════════════════════════════════
             SECTION 2 — TOOLBAR ROW
             Search on the left, Create button on the right.
             Visually separated from hero AND from filters.
        ══════════════════════════════════════════════════ -->
        <HBox alignment="CENTER_LEFT" spacing="12.0"
              style="-fx-background-color: #17191F;
                     -fx-background-radius: 14;
                     -fx-border-color: #2a2d32;
                     -fx-border-width: 1;
                     -fx-border-radius: 14;
                     -fx-padding: 12 16 12 16;">
            <children>
                <!-- Search field — takes available space but NOT full width -->
                <TextField fx:id="searchField"
                           prefWidth="300.0" maxWidth="400.0"
                           promptText="🔍   Rechercher un tableau..."
                           styleClass="search-field" />
                <Region HBox.hgrow="ALWAYS" />
                <!-- Create button — right-aligned, clearly separated -->
                <Button fx:id="btnCreateBoard" onAction="#handleCreateBoard"
                        mnemonicParsing="false"
                        styleClass="btn-primary"
                        text="＋  Créer un tableau" />
            </children>
        </HBox>

        <!-- Gap between toolbar and filters -->
        <Region prefHeight="16.0" />

        <!-- ══════════════════════════════════════════════════
             SECTION 3 — FILTER TABS + SECTION LABEL
             Label on the left, filter pills on the right.
        ══════════════════════════════════════════════════ -->
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <!-- Section label -->
                <Label text="Filtrer par :"
                       style="-fx-text-fill: #6a6d71; -fx-font-size: 12px; -fx-font-weight: bold;" />
                <!-- Filter pills -->
                <Button fx:id="btnFilterAll" onAction="#handleFilterAll"
                        mnemonicParsing="false"
                        styleClass="filter-btn-active"
                        text="Tous" />
                <Button fx:id="btnFilterPersonal" onAction="#handleFilterPersonal"
                        mnemonicParsing="false"
                        styleClass="filter-btn"
                        text="Personnels" />
                <Button fx:id="btnFilterTeam" onAction="#handleFilterTeam"
                        mnemonicParsing="false"
                        styleClass="filter-btn"
                        text="Équipe" />
            </children>
        </HBox>

        <!-- Gap between filters and grid -->
        <Region prefHeight="20.0" />

        <!-- ══════════════════════════════════════════════════
             SECTION 4 — BOARD GRID
             Scrollable card grid with consistent gaps
        ══════════════════════════════════════════════════ -->
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background-color: transparent;
                           -fx-background: transparent;
                           -fx-border-color: transparent;">
            <content>
                <FlowPane fx:id="boardGrid" hgap="18.0" vgap="18.0">
                    <padding>
                        <Insets bottom="16.0" right="2.0" />
                    </padding>
                </FlowPane>
            </content>
        </ScrollPane>

    </children>
</VBox>
