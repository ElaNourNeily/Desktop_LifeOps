<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="520.0" spacing="20.0"
      styleClass="popup-card"
      stylesheets="@board_style.css"
      xmlns="http://javafx.com/javafx/19"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.AIAssignmentPopupController">

    <padding>
        <Insets bottom="28.0" left="28.0" right="28.0" top="28.0" />
    </padding>

    <children>

        <!-- Header -->
        <VBox spacing="4.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <Label style="-fx-background-color: rgba(139,92,246,0.15); -fx-text-fill: #a78bfa; -fx-background-radius: 6; -fx-padding: 3 10; -fx-font-size: 10px; -fx-font-weight: bold;"
                               text="🤖 IA" />
                        <Label styleClass="popup-title" text="Suggestions d'Affectation" />
                    </children>
                </HBox>
                <Label styleClass="popup-subtitle"
                       text="Top recommandations basées sur la charge de travail et les compétences." />
            </children>
        </VBox>

        <!-- Recommendations container -->
        <VBox fx:id="recommendationsContainer" spacing="12.0" />

        <!-- Footer -->
        <HBox alignment="CENTER_RIGHT" spacing="12.0" style="-fx-padding: 4 0 0 0;">
            <children>
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="ignoreButton" mnemonicParsing="false" onAction="#handleIgnore"
                        style="-fx-background-color: transparent; -fx-text-fill: #8a8d91; -fx-cursor: hand; -fx-padding: 8 14; -fx-border-color: #2a2d32; -fx-border-width: 1; -fx-border-radius: 10; -fx-background-radius: 10;"
                        text="Annuler" />
            </children>
        </HBox>

    </children>
</VBox>
