<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="taskCardRoot" onMouseClicked="#handleCardClick"
      spacing="10.0" styleClass="task-card"
      stylesheets="@board_style.css"
      xmlns="http://javafx.com/javafx/19"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controller.task.TaskCardController">

    <padding>
        <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
    </padding>

    <children>

        <!-- Row 1: Priority pill + score dots + rank -->
        <HBox alignment="CENTER_LEFT" spacing="8.0">
            <children>
                <Label fx:id="lblPriorityBadge"
                       styleClass="priority-pill priority-moyenne-pill"
                       text="Moyenne" />
                <Region HBox.hgrow="ALWAYS" />
                <HBox fx:id="scoreDots" alignment="CENTER_RIGHT" spacing="4.0">
                    <children>
                        <Region fx:id="dot1" styleClass="intelligence-dot" />
                        <Region fx:id="dot2" styleClass="intelligence-dot" />
                        <Region fx:id="dot3" styleClass="intelligence-dot" />
                        <Region fx:id="dot4" styleClass="intelligence-dot" />
                    </children>
                </HBox>
                <Label fx:id="lblRankBadge" styleClass="rank-badge"
                       text="#1" visible="false" managed="false" />
            </children>
        </HBox>

        <!-- Row 2: Title -->
        <Label fx:id="lblTitle" styleClass="task-title"
               text="Design System Update" wrapText="true" />

        <!-- Row 3: Description -->
        <Label fx:id="lblDescription" styleClass="task-desc"
               text="description" wrapText="true" />

        <!-- Divider -->
        <Region prefHeight="1.0" styleClass="task-divider" />

        <!-- Row 4: Date + tracking badge -->
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="5.0">
                    <children>
                        <Label styleClass="task-info-tag" text="📅" />
                        <Label fx:id="lblEstimatedTime" styleClass="task-info-tag"
                               text="—" />
                        <Label fx:id="lblDeadlineAlert" styleClass="task-deadline-overdue"
                               text="⚠ Retard" visible="false" managed="false" />
                    </children>
                </HBox>
                <Region HBox.hgrow="ALWAYS" />
                <!-- Live tracking pill (only visible when timer is running) -->
                <HBox fx:id="trackingBadge" alignment="CENTER_LEFT" spacing="6.0"
                      styleClass="tracking-badge" visible="false" managed="false">
                    <children>
                        <Region fx:id="trackingDot" styleClass="tracking-dot" />
                        <Label fx:id="lblTrackingTime" styleClass="tracking-time"
                               text="00:00" />
                    </children>
                </HBox>
            </children>
        </HBox>

    </children>
</VBox>
