<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="taskCardRoot" onMouseClicked="#handleCardClick" spacing="10.0" styleClass="task-card" stylesheets="@board_style.css" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.TaskCardController">
   <children>
      <HBox alignment="CENTER_LEFT" spacing="8.0">
         <children>
            <Label fx:id="lblPriorityBadge" styleClass="priority-pill priority-moyenne-pill" text="Moyenne" />
            <Region HBox.hgrow="ALWAYS" />
            <HBox fx:id="scoreDots" alignment="CENTER_RIGHT" spacing="3.0">
               <children>
                  <Region fx:id="dot1" styleClass="intelligence-dot" />
                  <Region fx:id="dot2" styleClass="intelligence-dot" />
                  <Region fx:id="dot3" styleClass="intelligence-dot" />
                  <Region fx:id="dot4" styleClass="intelligence-dot" />
               </children>
            </HBox>
            <Label fx:id="lblRankBadge" styleClass="rank-badge" text="#1" visible="false" managed="false" />
         </children>
      </HBox>
      <Label fx:id="lblTitle" styleClass="task-title" text="Design System Update" wrapText="true" />
      <Label fx:id="lblDescription" styleClass="task-desc" text="description" wrapText="true" />
      <Region prefHeight="1.0" styleClass="task-divider" />
      <HBox alignment="CENTER_LEFT" spacing="12.0">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="4.0">
               <children>
                  <Label styleClass="task-info-tag" text="⏳" />
                  <Label fx:id="lblEstimatedTime" styleClass="task-info-tag" text="2026-04-27" />
                  <Label fx:id="lblDeadlineAlert" styleClass="task-deadline-overdue" text="Retard" visible="false" managed="false" />
               </children>
            </HBox>

            <Region HBox.hgrow="ALWAYS" />
            <!-- Tracking pill badge (renders only when tracking; no layout shift) -->
            <HBox fx:id="trackingBadge" alignment="CENTER_LEFT" spacing="6.0" styleClass="tracking-badge" visible="false" managed="false">
               <children>
                  <Region fx:id="trackingDot" styleClass="tracking-dot" />
                  <Label fx:id="lblTrackingTime" styleClass="tracking-time" text="00:00" />
               </children>
            </HBox>
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
   </padding>
</VBox>
